			}
		}

		Presets: {
			Tasty: {
				Name: "[i:4029] Tasty"
				Tooltip: Someone has left a frankly absurd amount of food lying around. Who made all of this?
			}

			Occult: {
				Name: "[i:SpiritReforged/ScryingPotItem] Occult"
				Tooltip: The failed experiments of countless mages and sorcerers litter the caverns.
			}
		}
	}

	Caves: {
		Name: Caves
		Description: Controls miscellaneous Cave additions.

		Members: {
			SignChance: {
				DisplayName: "[i:171] (Houses) Signs Chance"
				Tooltip: The denominator (1/x) of the chance for a sign to spawn in an underground house.
			}

			MannequinChance: {
				DisplayName: "[i:498] (Houses) Mannequin Chance"
				Tooltip: The denominator (1/x) of the chance for a mannequin to spawn in an underground house.
			}

			LoomChance: {
				DisplayName: "[i:332] (Houses) Loom Chance"
				Tooltip: The denominator (1/x) of the chance for a house to be a "loom house" - which adds in banners and a loom.
			}

			RareSignChance: {
				DisplayName: "[i:3617] (Houses) Rare Sign Rate"
				Tooltip: The denominator (1/x) of the chance for an underground sign to have a rare message.
			}

			CartSpawnRate: {
				DisplayName: "[i:13] (Decor) Minecart Rate"
				Tooltip: The multiplier to the maximum amount of ore minecarts that spawn in a world.
			}

			BoomshroomRate: {
				DisplayName: "[i:SpiritReforged/BoomShroom] (Decor) Shroom Rate"
				Tooltip: The multiplier to the maximum amount of Boomshrooms that spawn in a world.
			}

			CovesSpawnRate: {
				DisplayName: "[i:SpiritReforged/KoiTotem] (Coves) Multiplier"
				Tooltip:
					'''
					The multiplier to the maximum amount of Fishing Coves that spawn in a world. 
					This may cause issues with other mods that spawn structures.
					'''
			}

			NeonMossChance: {
				DisplayName: "[i:SpiritReforged/FlaskRadon] (Neon Moss) Custom Moss Chance"
				Tooltip: The likelihood that a custom Reforged glowing moss is chosen over a vanilla one (x/6).
			}

			StatueCountModifier: {
				DisplayName: "[i:SpiritReforged/WheezerStatueItem] (Statues) Maximum"
				Tooltip: The maximum amount of Reforged statues spawned in-world.
			}

			StructuresMax: {
				DisplayName: "[i:SpiritReforged/PotteryWheelItem] (Storage) Multiplier"
				Tooltip: The multiplier to the number of pottery structures in a world.
			}

			StructureScale: {
				DisplayName: "[i:SpiritReforged/PotteryWheelItem] (Storage) Scale"
				Tooltip: The scale applied to the size of pottery structures.
			}

			PotSpam: {
				DisplayName: "[i:SpiritReforged/PotteryWheelItem] (Storage) Pot Count"
				Tooltip: The minimum number of attempts pottery structures have to place pots.
			}
		}

		Presets: {
			Inhabited: {
				Name: "[i:498] Inhabited"
				Tooltip: There are signs of friendly explorers all across the Underground... what happened to them?
			}

			Empty: {
				Name: "[i:1176] Empty"
				Tooltip: Is anyone out there?
			}
		}
	}

	Ziggurat: {
		Name: Ziggurat
		Description: Controls aspects of the Ziggurat and its contents.

		Members: {
			UsedWidth: {
				DisplayName: "[i:SpiritReforged/RedSandstoneSlabItem] Width"
				Tooltip:
					'''
					The width used for determining the size of the Ziggurat, not necessarily the actual width.
					Higher-than-default values will force the Ziggurat to spawn over a Pyramid, as otherwise it may not spawn at all.
					'''
			}

			UsedHeight: {
				DisplayName: "[i:SpiritReforged/RedSandstoneSlabItem] Height"
				Tooltip:
					'''
					The height used for determining the size of the Ziggurat, not necessarily the actual width.
					Higher-than-default values will force the Ziggurat to spawn over a Pyramid, as otherwise it may not spawn at all.
					'''
			}

			MaxInfections: {
				DisplayName: "[i:SpiritReforged/PaleHiveItem] Max Infections"
				Tooltip: The amount of infections (nests) per floor of the Ziggurat. Ranges from 0 to this value.
			}

			PotChance: {
				DisplayName: "[i:SpiritReforged/BronzePotsItem] Pot Chance"
				Tooltip: Chance for pots to be placed in the Ziggurat.
			}

			LapisPotChance: {
				DisplayName: "[i:SpiritReforged/LapisPotsItem] Lapis Pot Chance"
				Tooltip: Chance for a pot placed to be a Lapis pot.
			}

			UncommonChance: {
				DisplayName: "[i:SpiritReforged/BiomePotsDesertItem] Uncommon Pot Chance"
				Tooltip: Chance for a pot placed to be an Uncommon pot.
			}

			MaxSpikeStripWidth: {
				DisplayName: "[i:SpiritReforged/NeedleTrapItem] Max Spike Strip Width"
				Tooltip: The maximum width of a spike strip.
			}

			SpikeStripChance: {
				DisplayName: "[i:SpiritReforged/NeedleTrapItem] Spike Strip Chance"
				Tooltip: The chance for a spike strip to be placed in non-special rooms.
			}

			SpecialRoomChance: {
				DisplayName: "[i:SpiritReforged/CarvedLapisWallItem] Special Room Chance"
				Tooltip:
					'''
					The chance that any Ziggurat room is a special room; that is, any of these:
					Library room, Storage room, Burial room
					'''
			}

			SkipRoomChance: {
				DisplayName: "[i:SpiritReforged/RedSandstoneBrickCrackedWallItem] Skip Room Chance"
				Tooltip: The chance for any room to be skipped instead of built.
			}

			ChestNormalization: {
				DisplayName: "[i:SpiritReforged/LapisChestItem] Chest Normalization"
				Tooltip:
					'''
					The factor at which the chest loot pool is normalized.
					The higher this value is, the more "even" all items are to roll.
					'''
			}

			DresserNormalization: {
				DisplayName: "[i:SpiritReforged/LapisDresserItem] Dresser Normalization"
				Tooltip:
					'''
					The factor at which the dresser loot pool is normalized.
					The higher this value is, the more "even" all items are to roll.
					'''
			}

			AncientBannerChance: {
				DisplayName: "[i:SpiritReforged/AncientBannerItem] Ancient Banner Chance"
				Tooltip: The chance for Ancient Banners to spawn.
			}

			BannerChance: {
				DisplayName: "[i:340] Banner Chance"
				Tooltip: The chance for vanilla banners to spawn.
			}

			CenserChance: {
				DisplayName: "[i:SpiritReforged/CenserItem] Censer Chance"
				Tooltip: The chance for censers to spawn.
			}

			TabletChance: {
				DisplayName: "[i:SpiritReforged/ScarabTabletOneItem] Ancient Tablet Chance"
				Tooltip: The chance for Ancient Tablets to spawn in non-Treasure rooms.
			}

			FloorDivotChance: {
				DisplayName: "[i:SpiritReforged/CrackedSandstoneItem] Floor Divot Chance"
				Tooltip: The chance for a floor divot (random weathering effect) to occur.
			}

			SandSplatChance: {
				DisplayName: "[i:169] Sand Splat Chance"
				Tooltip: The chance for a 'sand splat' (random weathering effect) to occur.
			}

			PillarChance: {
				DisplayName: "[i:SpiritReforged/RuinedSandstonePillarItem] Pillar Chance"
				Tooltip: The chance for a pillar to spawn.
			}

			LightChance: {
				DisplayName: "[i:SpiritReforged/SunDropper] Light Chance"
				Tooltip: The chance for a light ray to spawn.
			}

			ChestItemRange: {
				DisplayName: "[i:SpiritReforged/LapisChestItem] Chest Loot Amount"
				Tooltip: The range for the number of items in a chest. Three items are guaranteed per chest.
			}

			DresserItemRange: {
				DisplayName: "[i:SpiritReforged/LapisDresserItem] Dresser Loot Amount"
				Tooltip: The range for the number of items in a dresser.
			}
		}

		Presets: {
			Plagued: {
				Name: "[i:SpiritReforged/PaleHiveItem] Plagued"
				Tooltip: This Ziggurat has seen better days. The parts that haven't been buried by sand are crawling with Scarabs.
			}

			Opulent: {
				Name: "[i:SpiritReforged/LapisPotsItem] Opulent"
				Tooltip: Whoever built this Ziggurat spared no expense.
			}

			Perilous: {
				Name: "[i:SpiritReforged/NeedleTrapItem] Perilous"
				Tooltip: More loot, but more traps. A tantalizing prospect.
			}
		}
	}

