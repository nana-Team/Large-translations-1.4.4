			}

			ChestItemCountRange: {
				DisplayName: "[i:1298] (Oasis) Chest Item Range"
				Tooltip: The random range added to the minimum number of items in an underground Oasis chest.
			}

			FossilCount: {
				DisplayName: "[i:SpiritReforged/PolishedAmberItem] (Amber) Deposit Amount"
				Tooltip: The maximum number of amber veins in the Underground Desert.
			}

			FossilMultiplier: {
				DisplayName: "[i:SpiritReforged/AmberFossilSafeItem] (Amber) World Multiplier"
				Tooltip: The multiplier applied to the number of amber veins based on world size.
			}

			PatchScale: {
				DisplayName: "[i:SpiritReforged/AmberFossilSafeItem] (Amber) Deposit Scale"
				Tooltip: The scaling applied to the size of an amber vein.
			}

			RuinCount: {
				DisplayName: "[i:SpiritReforged/GildedRedSandstoneItem] (Ruins) Spawn Range"
				Tooltip: The range of how many underground desert ruins spawn per Oasis.
			}

			LightRange: {
				DisplayName: "[i:SpiritReforged/SunDropper] (Oasis) Light Ray Count"
				Tooltip: The minimum and additional random range for the amount of light rays in an underground oasis.
			}

			ChestItemRange: {
				DisplayName: "[i:1298] (Oasis) Chest Item Range"
				Tooltip: The range for the number of items in an underground Oasis chest.
			}

			RuinSegments: {
				DisplayName: "[i:SpiritReforged/RedSandstoneSlabItem] (Ruins) Segment Range"
				Tooltip: The range for how many segments an underground ruin may have.
			}
		}

		Presets: {
			Overgrown: {
				Name: "[i:2996] Overgrown"
				Tooltip: The oases in this desert are overgrown and wild. How do they thrive?
			}

			Petrified: {
				Name: "[i:154] Petrified"
				Tooltip: The sands hide aeons of fossilized ecosystems. Can you find them all?
			}

			Ruined: {
				Name: "[i:SpiritReforged/RedSandstoneSlabItem] Ruined"
				Tooltip: An ancient, long-forgotten civilization thrived below the Desert once. Their ruins remain.
			}
		}
	}
}

Enums: {
	OceanShape: {
		Default: {
			DisplayName: Vanilla
			Tooltip: Vanilla's default ocean generation. This disables most of Reforged's changes.
		}

		SlantedSine: {
			DisplayName: Slanted Sine
			Tooltip: A modified shape where the ocean is defined by a slanted sine wave.
		}

		Piecewise: {
			DisplayName: Piecewise
			Tooltip: A more complex piecewise function defines the ocean's shape.
		}

		Piecewise_M: {
			DisplayName: Piecewise (M)
			Tooltip: A modified version of the piecewise function with slightly different slopes.
		}

		Piecewise_V: {
			DisplayName: Reforged
			Tooltip: The finalized version of the piecewise preset with various minor modifications.
		}
	}
}
