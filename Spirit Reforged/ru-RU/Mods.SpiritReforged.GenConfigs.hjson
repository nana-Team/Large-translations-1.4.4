UI: {
	Min: Всё на мин.
	MinDescription:
		'''
		Устанавливает все настройки на значение наименьшей генерации.
		Таким образом, настройки в стиле «Максимум чего-то» будут установлены на минимум, 
		а настройки «Шанс на что-то (1/x)» будут установлены на максимум.
		'''
	Max: Всё на макс.
	MaxDescription:
		'''
		Устанавливает все настройки на значение наибольшей генерации.
		Таким образом, настройки в стиле «Максимум чего-то» будут установлены на максимум, 
		а настройки «Шанс на что-то (1/x)» будут установлены на минимум.
		'''
	Preset: Предустановка:
	NoPresets: (Предустановки отсутствуют)
	None: нет
	Reset: Сбросить
	ResetAll: Сбросить всё
	Prior: Пред.:
	Next: След.:
	True: Включено
	False: Отключено
	Total: всего {0}
	CustomPresetTooltip: Это ваша собственная предустановка!
	Create: Сохранить предустановку
	CantSave: (Вы не можете сохранить стандартные установки)
	Load: Загрузить набор предустановок
	HoverDescription: Открывает меню настройки некоторых элементов генерации мира из Spirit Reforged.
	FailedToLoad: Эта предустановка предназначена для другой страницы. Ожидаемая страница: {0}
	ConfigNotice:
		'''
		[c/AAAAFF:Разброс] определяется установкой минимальных и максимальных значений.
		Для генерации в игре будет использовано случайное значение в этом промежутке.
		'''
	LoadError: Произошла ошибка при загрузке предустановки ({0}). Проверьте файл client.log и сообщите об ошибке в нашем Discord:
	Duplicate: (Эта предустановка уже была добавлена)
}

Pages: {
	Savanna: {
		Name: Саванна
		Description: Настройка элементов генерации саванны.

		Presets: {
			Domesticated: {
				Name: "[i:224] Обжитость"
				Tooltip: Делает саванну более обжитой: больше следов цивилизации, меньше дикой природы.
			}

			Infested: {
				Name: "[i:SpiritReforged/TermiteJar] Термитник"
				Tooltip: Ой! Всё в термитах! Деревья, вероятно, будет трудно найти.
			}

			Bumpy: {
				Name: "[i:SpiritReforged/Drypowder] Холмы"
				Tooltip: Смотрите под ноги! Саванна станет полна холмов и возвышенностей.
			}
		}

		Members: {
			OverSpawn: {
				DisplayName: "[i:50] Саванна на спавне"
				Tooltip: Саванна сгенерируется прямо в точке появления игрока, как с сидом «savanna».
			}

			Steps: {
				DisplayName: "[i:SpiritReforged/DrywoodPlatformItem] Равнины"
				Tooltip: Количество равнин, с которыми сгенерируется саванна.
			}

			CampsiteChance: {
				DisplayName: "[i:SpiritReforged/SavannaCampfireItem] Шанс на лагерь"
				Tooltip: Устанавливает знаменатель (1/x) шанса генерации лагеря.
			}

			BaseTreeChance: {
				DisplayName: "[i:27] Шанс на акацию"
				Tooltip:
					'''
					Устанавливает знаменатель (1/x) шанса генерации акации на подходящем блоке.
					Этот шанс увеличивается до тех пор, пока не будет размещено дерево, после чего сбрасывается.
					'''
			}

			PotChance: {
				DisplayName: "[i:SpiritReforged/CommonPotsSavannaItem] Шанс на горшок"
				Tooltip:
					'''
					Устанавливает знаменатель (1/x) шанса генерации горшка.
					Горшки не перекрывают собой существующие тайлы,
					поэтому установка значения на 1 НЕ приведёт к генерации горшков на каждом блоке.
					'''
			}

			TermiteChance: {
				DisplayName: "[i:SpiritReforged/TermiteJar] Шанс на термитник"
				Tooltip: Устанавливает знаменатель (1/x) шанса генерации термитника.
			}
		}
	}

	SaltFlats: {
		Name: Солон. равнины
		Description: Настройка элементов генерации солончаковых равнин.

		Presets: {
			SunkenRuin: {
				Name: "[i:SpiritReforged/CobbledBrickItem] Затонувшие руины"
				Tooltip:
					'''
					Солончаковые равнины — это руины древней цивилизации,
					что была разрушена и смыта со временем.
					'''
			}

			BlankCanvas: {
				Name: "[i:SpiritReforged/GlidingItem] Чистый холст"
				Tooltip: Только пустая и необъятная отражающая поверхность.
			}

			Dessicated: {
				Name: "[i:1274] Иссушение"
				Tooltip: Вы не найдёте в биоме ни капли влаги, и в нём будет полно сухостоев.
			}
		}

		Members: {
			OverSpawn: {
				DisplayName: "[i:50] Солончаковые равнины на спавне"
				Tooltip: Солончаковые равнины сгенерируется прямо в точке появления игрока, как с сидом «salt».
			}

			RuinQty: {
				DisplayName: "[i:SpiritReforged/CalmingBellItem] Максимум руин"
				Tooltip:
					'''
					Устанавливает максимальное возможное количество сгенерированых руин в солончаковых равнинах.
					Это не гарантирует того, что все руины сгенерируются.
					'''
			}

			LakeRadius: {
				DisplayName: "[i:206] Радиус озёр"
				Tooltip: Устанавливает радиус озёр в солончаковых равнинах. Чем больше радиус, тем больше озеро.
			}

			CaveRadius: {
				DisplayName: "[i:SpiritReforged/SaltWallItem] Радиус пещер"
				Tooltip: Устанавливает радиус пещер в солончаковых равнинах. Чем больше радиус, тем больше пещера.
			}

			MaxSteps: {
				DisplayName: "[i:SpiritReforged/SaltBlockReflectiveItem] Максимум равнин"
				Tooltip: Устанавливает количество зеркальных равнин, с которыми сгенерируются солончаковые равнины.
			}

			StupaChance: {
				DisplayName: "[i:SpiritReforged/StoneStupasItem] Шанс на ступу"
				Tooltip:
					'''
					Устанавливает знаменатель (1/x) шанса генерации каменной ступы.
					Горшки не перекрывают собой существующие тайлы,
					поэтому установка значения на 1 НЕ приведёт к генерации горшков на каждом блоке.
					'''
			}

			TreeChance: {
				DisplayName: "[i:27] Шанс на сухостой"
				Tooltip:
					'''
					Устанавливает знаменатель (1/x) шанса генерации засохшего дерева на подходящем блоке.
					Этот шанс увеличивается до тех пор, пока не будет размещено дерево, после чего сбрасывается.
					'''
			}
		}
	}

	Surface: {
		Name: Поверхность
		Description: Настройка элементов генерации поверхности, добавляемых Reforged.

		Presets: {
			Whimsical: {
				Name: "[i:SpiritReforged/MidnightApple] Причудливый"
				Tooltip: Усеянные звёздной травой холмы, раскидистые и спокойные пшеничные поля... что вообще может пойти не так?
			}

			Treacherous: {
				Name: "[i:SpiritReforged/LeatherBackpack] Провал"
				Tooltip: По ландшафту могут быть разбросаны глубокие ущелья. Не смотрите вниз!
			}
		}

		Members: {
			HalfWidth: {
				DisplayName: "[i:133] Полуширина каньона"
				Tooltip: Устанавливает полуширину каньонов возле поверхности.
			}

			MaxDepth: {
				DisplayName: "[i:133] Макс. глубина каньона"
				Tooltip: Устанавливает максимальную возможную глубину каньонов.
			}

			SizeMultiplier: {
				DisplayName: "[i:747] Размер карстов"
				Tooltip: Устанавливает множитель размера всех углублений, формируемых карстами (заросших пещер).
			}

			FieldSize: {
				DisplayName: "[i:SpiritReforged/BotanistHat] Размер полей"
				Tooltip: Устанавливает ширину полей с пугалом.
			}

			ButterflyCountMax: {
				DisplayName: "[i:SpiritReforged/ButterflyStaff] Святыни бабочки"
				Tooltip:
					'''
					Устанавливает максимальное возможное количество сгенерированых святынь бабочки в мире.
					Это не гарантирует того, что все святыни сгенерируются.
					'''
			}

			HeroChance: {
				DisplayName: "[i:SpiritReforged/HerosMemorialStatueItem] Шанс на Памятник герою"
				Tooltip: Устанавливает знаменатель (1/x) шанса генерации Памятника герою.
			}

			MaxStargrassCount: {
				DisplayName: "[i:SpiritReforged/StarPowder] Участки звёздной травы"
				Tooltip:
					'''
					Устанавливает максимальное возможное количество сгенерированых участков со звёздной травой.
					Это не гарантирует того, что все участки сгенерируются.
					'''
			}

			ReforgedCaveWeight: {
				DisplayName: "[i:30] Коэфф. генерации пещер"
				Tooltip: Устанавливает коэффициент генерации типов пещер, добавляемых Reforged, вместо ванильных.
			}
		}
	}

	Ocean: {
