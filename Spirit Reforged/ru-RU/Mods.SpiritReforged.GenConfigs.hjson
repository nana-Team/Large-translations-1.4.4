	Ziggurat: {
		// Name: Ziggurat
		// Description: Controls aspects of the Ziggurat and its contents.

		Members: {
			UsedWidth: {
				// DisplayName: "[i:SpiritReforged/RedSandstoneSlabItem] Width"
				/* Tooltip:
					'''
					The width used for determining the size of the Ziggurat, not necessarily the actual width.
					Higher-than-default values will force the Ziggurat to spawn over a Pyramid, as otherwise it may not spawn at all.
					''' */
			}

			UsedHeight: {
				// DisplayName: "[i:SpiritReforged/RedSandstoneSlabItem] Height"
				/* Tooltip:
					'''
					The height used for determining the size of the Ziggurat, not necessarily the actual width.
					Higher-than-default values will force the Ziggurat to spawn over a Pyramid, as otherwise it may not spawn at all.
					''' */
			}

			MaxInfections: {
				// DisplayName: "[i:SpiritReforged/PaleHiveItem] Max Infections"
				// Tooltip: The amount of infections (nests) per floor of the Ziggurat. Ranges from 0 to this value.
			}

			PotChance: {
				// DisplayName: "[i:SpiritReforged/BronzePotsItem] Pot Chance"
				// Tooltip: Chance for pots to be placed in the Ziggurat.
			}

			LapisPotChance: {
				// DisplayName: "[i:SpiritReforged/LapisPotsItem] Lapis Pot Chance"
				// Tooltip: Chance for a pot placed to be a Lapis pot.
			}

			UncommonChance: {
				// DisplayName: "[i:SpiritReforged/BiomePotsDesertItem] Uncommon Pot Chance"
				// Tooltip: Chance for a pot placed to be an Uncommon pot.
			}

			MaxSpikeStripWidth: {
				// DisplayName: "[i:SpiritReforged/NeedleTrapItem] Max Spike Strip Width"
				// Tooltip: The maximum width of a spike strip.
			}

			SpikeStripChance: {
				// DisplayName: "[i:SpiritReforged/NeedleTrapItem] Spike Strip Chance"
				// Tooltip: The chance for a spike strip to be placed in non-special rooms.
			}

			SpecialRoomChance: {
				// DisplayName: "[i:SpiritReforged/CarvedLapisWallItem] Special Room Chance"
				/* Tooltip:
					'''
					The chance that any Ziggurat room is a special room; that is, any of these:
					Library room, Storage room, Burial room
					''' */
			}

			SkipRoomChance: {
				// DisplayName: "[i:SpiritReforged/RedSandstoneBrickCrackedWallItem] Skip Room Chance"
				// Tooltip: The chance for any room to be skipped instead of built.
			}

			ChestNormalization: {
				// DisplayName: "[i:SpiritReforged/LapisChestItem] Chest Normalization"
				/* Tooltip:
					'''
					The factor at which the chest loot pool is normalized.
					The higher this value is, the more "even" all items are to roll.
					''' */
			}

			DresserNormalization: {
				// DisplayName: "[i:SpiritReforged/LapisDresserItem] Dresser Normalization"
				/* Tooltip:
					'''
					The factor at which the dresser loot pool is normalized.
					The higher this value is, the more "even" all items are to roll.
					''' */
			}

			AncientBannerChance: {
				// DisplayName: "[i:SpiritReforged/AncientBannerItem] Ancient Banner Chance"
				// Tooltip: The chance for Ancient Banners to spawn.
			}

			BannerChance: {
				// DisplayName: "[i:340] Banner Chance"
				// Tooltip: The chance for vanilla banners to spawn.
			}

			CenserChance: {
				// DisplayName: "[i:SpiritReforged/CenserItem] Censer Chance"
				// Tooltip: The chance for censers to spawn.
			}

			TabletChance: {
				// DisplayName: "[i:SpiritReforged/ScarabTabletOneItem] Ancient Tablet Chance"
				// Tooltip: The chance for Ancient Tablets to spawn in non-Treasure rooms.
			}

			FloorDivotChance: {
				// DisplayName: "[i:SpiritReforged/CrackedSandstoneItem] Floor Divot Chance"
				// Tooltip: The chance for a floor divot (random weathering effect) to occur.
			}

			SandSplatChance: {
				// DisplayName: "[i:169] Sand Splat Chance"
				// Tooltip: The chance for a 'sand splat' (random weathering effect) to occur.
			}

			PillarChance: {
				// DisplayName: "[i:SpiritReforged/RuinedSandstonePillarItem] Pillar Chance"
				// Tooltip: The chance for a pillar to spawn.
			}

			LightChance: {
				// DisplayName: "[i:SpiritReforged/SunDropper] Light Chance"
				// Tooltip: The chance for a light ray to spawn.
			}

			ChestItemRange: {
				// DisplayName: "[i:SpiritReforged/LapisChestItem] Chest Loot Amount"
				// Tooltip: The range for the number of items in a chest. Three items are guaranteed per chest.
			}

			DresserItemRange: {
				// DisplayName: "[i:SpiritReforged/LapisDresserItem] Dresser Loot Amount"
				// Tooltip: The range for the number of items in a dresser.
			}
		}

		Presets: {
			Plagued: {
				// Name: "[i:SpiritReforged/PaleHiveItem] Plagued"
				// Tooltip: This Ziggurat has seen better days. The parts that haven't been buried by sand are crawling with Scarabs.
			}

			Opulent: {
				// Name: "[i:SpiritReforged/LapisPotsItem] Opulent"
				// Tooltip: Whoever built this Ziggurat spared no expense.
			}

			Perilous: {
				// Name: "[i:SpiritReforged/NeedleTrapItem] Perilous"
				// Tooltip: More loot, but more traps. A tantalizing prospect.
			}
		}
	}

	Desert: {
		// Name: Desert
		// Description: Controls various aspects of Reforged's Desert generation.

		Members: {
			PalmChanceLow: {
				// DisplayName: "[i:2504] (Oasis) Palm Chance (Low)"
				// Tooltip: Chance for a palm to be placed after at least one has already been placed.
			}

			PalmChanceHigh: {
				// DisplayName: "[i:2504] (Oasis) Palm Chance (High)"
				// Tooltip: Chance for a palm to be placed before at least one has already been placed.
			}

			CattailChance: {
				// DisplayName: "[i:2996] (Oasis) Cattail Chance"
				// Tooltip: Chance for a cattail to be placed.
			}

			OasisPlantChance: {
				// DisplayName: "[i:SpiritReforged/PineappleSeeds] (Oasis) Oasis Plant Chance"
				// Tooltip: Chance for an Oasis Plant to be placed.
			}

			GlowflowerChance: {
				// DisplayName: "[i:4045] (Oasis) Glowflower Chance"
				// Tooltip: Chance for a Glowflower to be placed.
			}

			PineappleChance: {
				// DisplayName: "[i:4294] (Oasis) Pineapple Chance"
				// Tooltip: Chance for a Pineapple to be placed.
			}

			SeaOatsChance: {
				// DisplayName: "[i:SpiritReforged/WheatgrassSeedPouch] (Oasis) Sea Oats Chance"
				// Tooltip: Chance for Sea Oats to be placed. Sea oats are the grassy grain plants near the Ocean or Oases.
			}

			PoolWidth: {
				// DisplayName: "[i:206] (Oasis) Pool Width"
				// Tooltip: The range for an underground Oasis's pool's width (in tiles).
			}

			PoolDepth: {
				// DisplayName: "[i:206] (Oasis) Pool Depth"
				// Tooltip: The range for an underground Oasis's pool's depth (in tiles).
			}

			MainNormalization: {
				// DisplayName: "[i:1298] (Oasis) Main Normalization"
				/* Tooltip:
					'''
					The factor at which the main item loot pool is normalized.
					The higher this value is, the more "even" all items are to roll.
					''' */
			}

			ItemNormalization: {
				// DisplayName: "[i:1298] (Oasis) Other Normalization"
				/* Tooltip:
					'''
					The factor at which the non-main item loot pool is normalized.
					The higher this value is, the more "even" all items are to roll.
					''' */
			}

			ChestItemCountMin: {
				// DisplayName: "[i:1298] (Oasis) Chest Item Minimum"
				// Tooltip: The minimum amount of items in an underground Oasis chest.
			}

			ChestItemCountRange: {
				// DisplayName: "[i:1298] (Oasis) Chest Item Range"
				// Tooltip: The random range added to the minimum number of items in an underground Oasis chest.
			}

			FossilCount: {
				// DisplayName: "[i:SpiritReforged/PolishedAmberItem] (Amber) Deposit Amount"
				// Tooltip: The maximum number of amber veins in the Underground Desert.
			}

			FossilMultiplier: {
				// DisplayName: "[i:SpiritReforged/AmberFossilSafeItem] (Amber) World Multiplier"
				// Tooltip: The multiplier applied to the number of amber veins based on world size.
			}

			PatchScale: {
				// DisplayName: "[i:SpiritReforged/AmberFossilSafeItem] (Amber) Deposit Scale"
				// Tooltip: The scaling applied to the size of an amber vein.
			}

			RuinCount: {
				// DisplayName: "[i:SpiritReforged/GildedRedSandstoneItem] (Ruins) Spawn Range"
				// Tooltip: The range of how many underground desert ruins spawn per Oasis.
			}

			LightRange: {
				// DisplayName: "[i:SpiritReforged/SunDropper] (Oasis) Light Ray Count"
				// Tooltip: The minimum and additional random range for the amount of light rays in an underground oasis.
			}

			ChestItemRange: {
				// DisplayName: "[i:1298] (Oasis) Chest Item Range"
				// Tooltip: The range for the number of items in an underground Oasis chest.
			}

			RuinSegments: {
				// DisplayName: "[i:SpiritReforged/RedSandstoneSlabItem] (Ruins) Segment Range"
				// Tooltip: The range for how many segments an underground ruin may have.
			}
		}

		Presets: {
			Overgrown: {
				// Name: "[i:2996] Overgrown"
				// Tooltip: The oases in this desert are overgrown and wild. How do they thrive?
			}

			Petrified: {
				// Name: "[i:154] Petrified"
				// Tooltip: The sands hide aeons of fossilized ecosystems. Can you find them all?
			}

			Ruined: {
				// Name: "[i:SpiritReforged/RedSandstoneSlabItem] Ruined"
				// Tooltip: An ancient, long-forgotten civilization thrived below the Desert once. Their ruins remain.
			}
		}
	}
}

Enums: {
	OceanShape: {
		Default: {
			DisplayName: Ванилла
			Tooltip: Ванильная генерация океана. Отключает большинство изменений Reforged.
		}

		SlantedSine: {
			DisplayName: Синусоида
			Tooltip: Генерация океана, определяемая наклонённой синусоидой волной.
		}

		Piecewise: {
			DisplayName: Кусочная
			Tooltip: Более сложная генерация океана, определяемая кусочно-заданной функцией.
		}

		Piecewise_M: {
			DisplayName: Кусочная 2
			Tooltip: Генерация на базе кусочно-заданной функции с немного изменённой крутизной на отдельных участках.
		}

		Piecewise_V: {
			DisplayName: Reforged
			Tooltip: Финальная версия генерации на базе кусочно-заданной функции с небольшими изменениями.
		}
	}
}
