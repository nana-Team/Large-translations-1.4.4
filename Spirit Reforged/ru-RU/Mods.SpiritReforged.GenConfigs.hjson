			KelpChance: {
				DisplayName: "[i:SpiritReforged/Kelp] Шанс на ламинарию"
				Tooltip: Устанавливает знаменатель (1/x) шанса генерации ламинарии в океане.
			}

			KelpMaxHeight: {
				DisplayName: "[i:SpiritReforged/Kelp] Высота для ламинарий"
