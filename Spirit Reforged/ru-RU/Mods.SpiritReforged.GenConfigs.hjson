			StructuresMax: {
				DisplayName: "[i:SpiritReforged/PotteryWheelItem] Множ. гончарных"
				Tooltip: Устанавливает множитель максимального возможного количества гончарных мастерских в мире.
			}

			StructureScale: {
				DisplayName: "[i:SpiritReforged/PotteryWheelItem] Размер гончарных"
				Tooltip: Устанавливает множитель размера гончарных мастерских.
			}

			PotSpam: {
				DisplayName: "[i:SpiritReforged/PotteryWheelItem] Горшки в гончарных"
				Tooltip:
					'''
					Устанавливает максимальное возможное количество сгенерированых горшок в гончарной мастерской.
					Это не гарантирует того, что все горшки сгенерируются.
					'''
			}
		}

		Presets: {
			Inhabited: {
				Name: "[i:498] Заселённый"
				Tooltip: В подземелье полно следов предыдущих исследователей... Что с ними случилось?
			}

			Empty: {
				Name: "[i:1176] Пустой"
				Tooltip: Тут кто-нибудь есть?
			}
		}
	}

	Ziggurat: {
		Name: Зиккурат
		Description: Настройка элементов генерации Зиккурата и его содержимого.

		Members: {
			UsedWidth: {
				DisplayName: "[i:SpiritReforged/RedSandstoneSlabItem] Ширина"
				Tooltip:
					'''
					Задаёт базовую ширину Зиккурата при генерации. Реальная ширина структуры может отличаться.
					При значениях выше базового Зиккурат может перекрывать пирамиды,
					чтобы предотвратить ситуации, при которых структура не генерируется вообще.
					'''
			}

			UsedHeight: {
				DisplayName: "[i:SpiritReforged/RedSandstoneSlabItem] Высота"
				Tooltip:
					'''
					Задаёт базовую высоту Зиккурата при генерации. Реальная высота структуры может отличаться.
					При значениях выше базового Зиккурат может перекрывать пирамиды,
					чтобы предотвратить ситуации, при которых структура не генерируется вообще.
					'''
			}

			MaxInfections: {
				DisplayName: "[i:SpiritReforged/PaleHiveItem] Максимум гнёзд"
				Tooltip: Устанавливает максимальное возможное количество сгенерированых гнёзд на этаже Зиккурата.
			}

			PotChance: {
				DisplayName: "[i:SpiritReforged/BronzePotsItem] Шанс на горшок"
				Tooltip:
					'''
					Устанавливает шанс генерации горшка.
					Горшки не перекрывают собой существующие тайлы,
					поэтому установка значения на 1 НЕ приведёт к генерации горшков на каждом блоке.
					'''
			}

			LapisPotChance: {
				DisplayName: "[i:SpiritReforged/LapisPotsItem] Шанс на лаз. горшок"
				Tooltip: Устанавливает шанс того, что сгенерированный горшок окажется лазуритовым.
			}

			UncommonChance: {
				DisplayName: "[i:SpiritReforged/BiomePotsDesertItem] Шанс на ред. горшок"
				Tooltip: Устанавливает шанс того, что сгенерированный горшок окажется редким.
			}

			MaxSpikeStripWidth: {
				DisplayName: "[i:SpiritReforged/NeedleTrapItem] Ширина ловушек"
				Tooltip: Устанавливает максимальную возможную ширину ловушки с иглой.
			}

			SpikeStripChance: {
				DisplayName: "[i:SpiritReforged/NeedleTrapItem] Шанс на ловушку"
				Tooltip: Устанавливает шанс генерации ловушки с иглой в обычных комнатах.
			}

			SpecialRoomChance: {
				DisplayName: "[i:SpiritReforged/CarvedLapisWallItem] Шанс на особую комнату"
				Tooltip:
					'''
					Устанавливает шанс генерации особой комнаты в Зиккурате:
					библиотеки, склада или погребальной.
					'''
			}

			SkipRoomChance: {
				DisplayName: "[i:SpiritReforged/RedSandstoneBrickCrackedWallItem] Шанс на пропуск комнаты"
				Tooltip: Устанавливает шанс пропустить генерацию комнаты на этаже.
			}

			ChestNormalization: {
				DisplayName: "[i:SpiritReforged/LapisChestItem] Нормализация сундуков"
				Tooltip:
					'''
					Определяет степень нормализации списка содержимого сундуков.
					Чем выше это значение, тем более равномерно распределяются шансы появления всех предметов.
					'''
			}

			DresserNormalization: {
				DisplayName: "[i:SpiritReforged/LapisDresserItem] Нормализация комодов"
				Tooltip:
					'''
					Определяет степень нормализации списка содержимого комодов.
					Чем выше это значение, тем более равномерно распределяются шансы появления всех предметов.
					'''
			}

			AncientBannerChance: {
				DisplayName: "[i:SpiritReforged/AncientBannerItem] Шанс на древ. знамя"
				Tooltip: Устанавливает шанс генерации древнего знамени.
			}

			BannerChance: {
				DisplayName: "[i:340] Шанс на знамя"
				Tooltip: Устанавливает шанс генерации ванильных знамён.
			}

			CenserChance: {
				DisplayName: "[i:SpiritReforged/CenserItem] Шанс на кадило"
				Tooltip: Устанавливает шанс генерации кадило.
			}

			TabletChance: {
				DisplayName: "[i:SpiritReforged/ScarabTabletOneItem] Шанс на скрижаль"
				Tooltip: Устанавливает шанс генерации скрижали в не складах.
			}

			FloorDivotChance: {
				DisplayName: "[i:SpiritReforged/CrackedSandstoneItem] Шанс на расщелины пола"
				Tooltip: Устанавливает шанс генерации расщелин (случайного эффекта выветривания) в полу.
			}

			SandSplatChance: {
				DisplayName: "[i:169] Шанс на песчаный завал"
				Tooltip: Устанавливает шанс генерации песчаных завалов (случайного эффекта выветривания).
			}

			PillarChance: {
				DisplayName: "[i:SpiritReforged/RuinedSandstonePillarItem] Шанс на колонну"
				Tooltip: Устанавливает шанс генерации колонны.
			}

			LightChance: {
				DisplayName: "[i:SpiritReforged/SunDropper] Шанс на луч солнца"
				Tooltip: Устанавливает шанс генерации магического луча света.
			}

			ChestItemRange: {
				DisplayName: "[i:SpiritReforged/LapisChestItem] Кол-во содержимого сундуков"
				Tooltip: Устанавливает значение разброса количества содержимого в сундуке. В каждом сундуке будет как минимум 3 предмета.
			}

			DresserItemRange: {
				DisplayName: "[i:SpiritReforged/LapisDresserItem] Кол-во содержимого комодов"
				Tooltip: Устанавливает значение разброса количества содержимого в комоде.
			}
		}

		Presets: {
			Plagued: {
				Name: "[i:SpiritReforged/PaleHiveItem] Улей"
				Tooltip: Зиккурат переживает не лучшие времена. Комнаты, что не засыпало песком, теперь кишат скарабеями.
			}

			Opulent: {
				Name: "[i:SpiritReforged/LapisPotsItem] Роскошный"
				Tooltip: Те, кто строили этот зиккурат, денег не жалели.
			}

			Perilous: {
				Name: "[i:SpiritReforged/NeedleTrapItem] Опасный"
				Tooltip: Больше добычи, но и больше ловушек. Весьма заманчиво.
			}
		}
	}

	Desert: {
		Name: Пустыня
		Description: Настройка элементов генерации пустыни, добавляемых Reforged.

		Members: {
			PalmChanceLow: {
				DisplayName: "[i:2504] Шанс на пальму (нач.)"
				Tooltip: Устанавливает шанс генерации пальмы в подземном оазисе после размещения первой пальмы.
			}

			PalmChanceHigh: {
				DisplayName: "[i:2504] Шанс на пальму (пос.)"
				Tooltip: Устанавливает шанс генерации пальмы в подземном оазисе до размещения первой пальмы.
			}

			CattailChance: {
				DisplayName: "[i:2996] Шанс на рогоз"
				Tooltip: Устанавливает шанс генерации рогоза в подземном оазисе.
			}

			OasisPlantChance: {
				DisplayName: "[i:SpiritReforged/PineappleSeeds] Шанс на растительность"
				Tooltip: Устанавливает шанс генерации растительности в подземном оазисе.
			}

			GlowflowerChance: {
				DisplayName: "[i:4045] Шанс на цветы"
				Tooltip: Устанавливает шанс генерации светящегося цветка в подземном оазисе.
			}

			PineappleChance: {
				DisplayName: "[i:4294] Шанс на ананас"
				Tooltip: Устанавливает шанс генерации ананаса в подземном оазисе.
			}

			SeaOatsChance: {
				DisplayName: "[i:SpiritReforged/WheatgrassSeedPouch] Шанс на морской овёс"
				Tooltip:
					'''
					Устанавливает шанс генерации морского овса в подземном оазисе.
					Морской овёс — это вид короткой травы, растущий возле океана и обычного оазиса.
					'''
			}

			PoolWidth: {
				DisplayName: "[i:206] Разброс ширины озера"
				Tooltip: Устанавливает значение разброса ширины озера подземного оазиса (в тайлах).
			}

			PoolDepth: {
				DisplayName: "[i:206] Разброс глубины озера"
				Tooltip: Устанавливает значение разброса глубины озера подземного оазиса (в тайлах).
			}

			MainNormalization: {
				DisplayName: "[i:1298] Нормализация основ. добычи"
				Tooltip:
					'''
					Определяет степень нормализации списка основного содержимого сундуков в подземном оазисе.
					Чем выше это значение, тем более равномерно распределяются шансы появления всех предметов.
					'''
			}

			ItemNormalization: {
				DisplayName: "[i:1298] Нормализация доп. добычи"
				Tooltip:
					'''
					Определяет степень нормализации списка дополнительного содержимого сундуков в подземном оазисе.
					Чем выше это значение, тем более равномерно распределяются шансы появления всех предметов.
					'''
			}

			FossilCount: {
				DisplayName: "[i:SpiritReforged/PolishedAmberItem] Макс. янтарных жил"
				Tooltip: Устанавливает максимальное возможное количество янтарных жил в подземной пустыне.
			}

			FossilMultiplier: {
				DisplayName: "[i:SpiritReforged/AmberFossilSafeItem] Множ. размера мира"
				Tooltip: Устанавливает множитель, применяемый к количеству янтарных жил в зависимости от размера мира.
			}

			PatchScale: {
				DisplayName: "[i:SpiritReforged/AmberFossilSafeItem] Множ. размера жил"
				Tooltip: Устанавливает множитель размера янтарных жил.
			}

			RuinCount: {
				DisplayName: "[i:SpiritReforged/GildedRedSandstoneItem] Разброс кол-ва руин"
				Tooltip: Устанавливает значение разброса количества пустынных руин, генерируемых в зависимости от количества оазисов в мире.
			}

			LightRange: {
				DisplayName: "[i:SpiritReforged/SunDropper] Кол-во лучей солнца"
				Tooltip: Устанавливает значение разброса количества магического света в подземном оазисе.
			}

			ChestItemRange: {
				DisplayName: "[i:1298] Разброс содержимого сундуков"
				Tooltip: Устанавливает значение разброса количества предметов в сундуках подземного оазиса.
			}

			RuinSegments: {
				DisplayName: "[i:SpiritReforged/RedSandstoneSlabItem] Разброс кол-ва сегментов"
				Tooltip: Устанавливает значение разброса количества сегментов, из которых будут состоять руины подземной пустыни.
			}
		}

		Presets: {
			Overgrown: {
				Name: "[i:2996] Заросший"
				Tooltip: Оазисы в этой пустыне полны жизни и растительности и одичали. Как им только это удалось?
			}

			Petrified: {
				Name: "[i:154] Окаменевший"
				Tooltip: Пески скрывают целые эпохи окаменевших экосистем. Сможете ли вы найти их все?
			}

			Ruined: {
				Name: "[i:SpiritReforged/RedSandstoneSlabItem] Заброшенный"
				Tooltip: Когда-то под этой пустыней процветала древняя, давно забытая цивилизация. Сейчас от неё остались лишь руины.
			}
		}
	}
}

Enums: {
	OceanShape: {
		Default: {
			DisplayName: Ванилла
			Tooltip: Ванильная генерация океана. Отключает большинство изменений Reforged.
		}

		SlantedSine: {
			DisplayName: Синусоида
			Tooltip: Генерация океана, определяемая наклонённой синусоидой волной.
		}

		Piecewise: {
			DisplayName: Кусочная
			Tooltip: Более сложная генерация океана, определяемая кусочно-заданной функцией.
		}

		Piecewise_M: {
			DisplayName: Кусочная 2
			Tooltip: Генерация на базе кусочно-заданной функции с немного изменённой крутизной на отдельных участках.
		}

		Piecewise_V: {
			DisplayName: Reforged
			Tooltip: Финальная версия генерации на базе кусочно-заданной функции с небольшими изменениями.
		}
	}
}
