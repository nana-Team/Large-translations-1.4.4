SpiritClientConfig: {
	DisplayName: Клиентская конфигурация

	ScreenShake: {
		Label: Множитель силы тряски экрана
		Tooltip: Определяет уровень силы тряски экрана, создаваемой контентом Spirit.
	}

	DistortionConfig: {
		Label: Screen Distortion
		Tooltip: Enables screen distortion while in the Spirit Biome or when fighting the Starplate Voyager
	}

	ForegroundParticles: {
		Label: Foreground Particles
		Tooltip: Enables extra particles in the foreground under certain conditions
	}

	AutoReuse: {
		Label: Auto-Reuse Tooltip
		Tooltip: Enables an extra line in weapon tooltips displaying if an item is auto-reuse/autoswing
	}

	QuickSell: {
		Label: Механика быстрой продажи предметов
		Tooltip: Enables the quick-sell feature, which allows for easily selling all unwanted items to NPCs
	}

	AmbientSounds: {
		Label: Звуковые эффекты
		Tooltip: Добавляет новые звуковые эффекты для некоторых биомов.
	}

	LeafFall: {
		Label: Эффект падающей листвы
		Tooltip:
			'''
			Добавляет фоновый эффект падающей листвы для тихих ночей и терновника.
			Может вызвать странные последствия при игре с Terraria Overhaul.
			'''
	}

	QuestBookLocation: {
		Label: Расположение книги заданий
		Tooltip: Определяет, в какой части инвентаря будет отображаться кнопка открытия книги заданий.
	}

	QuestBookSwitching: {
		Label: Переключаться на вкладку открытого задания
		Tooltip: Если задание, которое вы открыли в книге заданий, изменит своё состояние, то вас автоматически перебросит на соответствующую вкладку.
	}

	ShowNPCQuestNotice: {
		Label: Восклицательный знак над НИПами
		Tooltip: Над НИПами, у которых можно взять новое задание, будет показываться иконка восклицательного знака.
	}

	DoubleHideoutGeneration: {
		Label: Генерировать таинственную башню и укрытие бандитов вместе
		Tooltip:
			'''
			Позволяет генерировать обе структуры в новых мирах, а не только одну.
			Рекомендуется только для больших миров.
			'''
	}

	OceanShape: {
		Label: Форма океана
		Tooltip:
			'''
			Определяет способ генерации океана.
			По умолчанию используется тип «Кусочная (V)» и рекомендуется для прохождения мода.
			'''
	}

	VentCritters: {
		Label: Живность возле гидротермальных источников
		Tooltip:
			'''
			Рядом с гидротермальными источниками будут появляться различная живность.
			Она не влияет на частоту появления обычных врагов, но будет учитываться в общем лимите существ в мире.
			'''
	}

	SurfaceWaterTransparency: {
		Label: Прозрачная вода в океане
		Tooltip:
			'''
			Делает воду в океане более прозрачной.
			Это не влияет на другие биомы.
			'''
	}

	EnemyFishing: {
		Label: Вылавливание врагов
		Tooltip: Во время рыбалки можно будет выловить некоторых новых врагов.
	}

	AuroraEnabled: {
		Label: Эффект северного сияния
		Tooltip: Определяет, будут ли видно эффекты северного сияния во время события.
	}

	EnableSepulchres: {
		Label: Тёмные склепы
		Tooltip:
			'''
			Позволяет переключать генерацию тёмных склепов в новых мирах.
			Отключите, если тёмные склепы вызывают проблемы при игре с другими модами.
			'''
	}

	ForceClassicZiggurat: {
		Label: Принудительно генерировать классический зиккурат
		Tooltip:
			'''
			Зиккурат из Spirit Classic будет генерироваться в новых мирах даже с включённым Spirit Reforged.
			Из-за этого классический зиккурат может начать перекрывать другие структуры.
			'''
	}

	Headers: {
		Visuals: "[i:SpiritMod/MoonStone] Визуальные эффекты"
		QoL: "[i:SpiritMod/PirateCrate] Удобства"
		Ambience: "[i:SpiritMod/GladeWreath] Звуковые эффекты"
		Quests: "[i:SpiritMod/MapScroll] Задания"
		Generation: "[i:SpiritMod/BismiteCrystal] Генерация мира"
		Oceans: "[i:SpiritMod/BlackPearl] Океан"
		Fishing: "[i:SpiritMod/HornetfishQuest] Рыбалка"
	}
}

QuestInvLocation: {
	Tooltip: ""

	Minimap: {
		Label: У мини-карты
		Tooltip: ""
	}

	Trashcan: {
		Label: У мусорки
		Tooltip: ""
	}

	FarLeft: {
		Label: Слева
		Tooltip: ""
	}
}

OceanShape: {
	Tooltip: ""

	Default: {
		Label: Стандартная
		Tooltip: Ванильная генерация океана. Отключает все изменения Spirit.
	}

	SlantedSine: {
		Label: Синусоида
		Tooltip: Генерация океана, определяемая наклонённой синусоидой волной.
	}

	Piecewise: {
		Label: Кусочная
		Tooltip: Более сложная генерация океана, определяемая кусочно-заданной функцией.
	}

	Piecewise_M: {
		Label: Кусочная (M)
		Tooltip: Генерация на базе кусочно-заданной функции с немного изменённой крутизной на отдельных участках.
	}

	Piecewise_V: {
		Label: Кусочная (V)
		Tooltip: Финальная версия генерации на базе кусочно-заданной функции с небольшими изменениями.
	}
}

