# I'm very sorry to whoever's translating this. Best of luck, and godspeed. - GabeHasWon

# This is actually only used for the Lifeform Analyzer's (Quest) <NPCName>.
Quest: Задание
QuestBook: Книга заданий
Residents: Жители хотят поговорить с вами. Пообщайтесь с ними, чтобы получить новые задания!
ChatOpenBook: Нажмите на задание в чате, чтобы открыть его в книге!
# This formats to "You have completed a quest! <Quest Name>" in-game. The sQ?:{0} is a quest chat tag.
QuestCompleteChat: Задание выполнено! [[sQ/{0}:{1}]]
QuestOutOfTimeChat: Время на выполнение задания [[sQ/{0}:{1}]] истекло!
QuestRelockedChat: Задание [[sQ/{0}:{1}]] снова заблокировано.
NewQuestChat: Получено новое задание! [[sQ/{0}:{1}]]
OpenJournal: Нажмите Q, чтобы открыть книгу заданий!
OpenHUD: Нажмите C, чтобы отслеживать прогресс через интерфейс!
QuestsFull: Вы не можете взять больше заданий.
StopQuest: Вы уверены? Это [c/910000:сбросит весь прогресс].
Undiscovered: Это задание ещё не открыто.
# These are all used for minor parts of quests, such as "Catch 2 Fish" or similar.
TalkTo: Поговорить: {0}
# Same as above. Used for "Explore <area>" in-game.
Explore: "Исследовать "
Retrieve: Получить: {1} ({0} шт.)
Catch: Поймать: {1} ({0} шт.)
Kill: Убить: {1} ({0} шт.)
PluralSuffix: ""
Comma: ", "
Or: " или "
Craft: Создать: {1} ({0} шт.)
Capture: Поймать: {1} ({0} шт.)
Harvest: Собрать: {1} ({0} шт.)
OptionalGather: Собрать: {1} ({0} шт.) (необязательно)
Objectives: Задачи
Activate: Начать
Deactivate: Отменить
ClaimRewards: Забрать!
# Used for quest clients. Formats to "The <NPC Title>" in-game. The space is necessary. This also looks like a meme.
The: ""
# Same as above for both of the below, but less funny.
Client: "Заказчик: "
Rewards: Награды
# Used for chat quest snippets.
ViewQuest: Нажмите, чтобы посмотреть это задание в книге!
QuesTime: "{0}м {1}с"

Buttons: {
	# Quest states
	Active: Активно
	Completed: Завершено
	Available: Доступно
	# Quest types
	All: Всё
	Main: Основное
	Explorer: Исследование
	Forager: Собирательство
	Slayer: Охота
	Designer: Строительство
	Other: Другое
}

QuestInfo: {
	# All quests will have a Name and a Description. The rest is dependent on what the quest does.
	DefaultQuest: {
		Name: Default Quest
		Description: Placeholder for unlocalized quests.
	}

	AncestralWorship: {
		Name: Поклонение предкам
		Description: Ещё когда мы с профессором Лейватс исследовали терновник, я не раз слышал, как она говорила о каких-то здоровенных статуях, которые возводила местная цивилизация. Со временем все они обрушились, но мы ведь можем попробовать их воссоздать!
	}

	AnglerStatueQuest: {
		Name: Рыба покрупнее
		Description: Тебе не кажется, что я — лучший рыбак во всём мире? Конечно не кажется, ведь так оно и есть! Но ходят слухи, что на берег порой выносит ящики с такими грудами рыбы, что я, мол, в жизни бы не поймал! Походи-ка по пляжу и докажи всем, что эти слухи — полная чепуха! Говорю же, нет там никаких ящиков, иди давай!
		AppeaseLine: Утешить рыбака, поймав для него немного рыбы
		TalkLine: Поговорить с рыбаком
		AskGuide: Или попросить совета у гида
		AnglerStatueDemand: *всхлипывает* Чего тебе? Утешить меня хочешь? Говоришь, что сделаешь для меня ВСЁ ЧТО УГОДНО? Как это нет? Я же слышал! Поздно! Хочу, чтоб те ящики расплавили к чертям и отлили из них огромную статую наполовину рыбака, наполовину акулы, чтобы те неудачники с завода знали, кто тут главный рыболов! Всё, это твоё ведь обещание, иди давай!
		CatchTooManyFish: А эта тухлятина мне чем поможет? Или ты тоже выделываешься, что лучше меня рыбу ловишь?! Твоё дело — молча выполнять для меня задания, и всё! Вали отсюда!
		GuideCheckin: Рыбак горюет, да? Ну, в конце концов, он же ещё ребёнок, конечно, его такое огорчить может. Будет трудно, но спроси, можно ли что-нибудь сделать для него, чтоб ему стало лучше.
		GiveToAngler: Отдать красных люцианов рыбаку
		ShowAnglerCreation: Показать своё творение рыбаку
		ShowAnglerCrates: Показать упаковочные ящики рыбаку
		CheerUp: Это самая крутецкая вещь в мире! Промышленному рыбоводству никогда не сломить мой дух, ведь у них, уверен, нет такой статуи наполовину человека, наполовину акулы! Мне очень понравилось, так что держи награду. Немедля поставь эту статую на видное место! Я договорюсь с торговцем, чтобы тот начал продавать копии этого чуда!
		Defeated: ЧЕГО?! Завод по... выращиванию... рыбы? В промышленных... масштабах? С использованием... технологий? Я думал, что я тут лучше всех ловлю рыбу! Отстой. *всхлипывает* Спасибо, теперь у меня настроение испортилось, бестолочь. Проваливай отсюда.
	}

	AuroraStagQuest: {
		Name: Как приручить звезду
		Description: Здорово! В последнее время мир кишит всякими опасностями, но уверяю, всё не так уж и плохо! Мои разведчики доложили мне о громадном и изящном олене, выходящем на свет только во время северного сияния. Мы, кажется, даже знаем его любимое лакомство! Он очень пугливый, однако, так что давай с ним без резких движений.
		Objective: Медленно подойти к полярному оленю и покормить его мерзлоягодой
	}

	BareNecessities: {
		Name: Без этого никак
		Description: Знаешь, я реально ценю то, что меня не только из того ужасного места вытащили, но и без крыши над головой не оставили. И всё же, не хочу показаться грубым, но-о-о... послушай, этому месту правда не помешал бы декор. Начни с создания мастерской натуралиста: на ней сможешь сделать кучу красивых штуковин.
	}

	BlastFromThePast: {
		Name: Веяние прошлого
		Description: Смотрю, те самые газоразрядные трубки у тебя уже есть. Рад, что к моему совету хоть кто-то прислушался, но давай не будем на этом останавливаться! Собери-ка пару кусков древнего мрамора и создай гиперпространственный бюст. Поверь, с ним любое место станет в разы атмосфернее!
	}

	FirstAdventure: {
		Name: Первое приключение
		Description: Ну что, среди приключенцев пополнение? Тогда собирай вещи: есть тебе задание! Я было хотел сшить тебе комплект брони, чтобы помочь в твоих начинаниях, но стая паршивых крюкохвостых мышей вырвала нужное для этого полотно прочной ткани прямо из моих рук! Обитают они в лесу, а наружу выходят только ночью. Выручи меня, достань ту ткань и сделай эту броню себе.
	}

	RaidingTheStars: {
		Name: Разграбить космос
		Description: Так понимаю, поле астероидов уже исследовано? Согласно моим источникам, в последнее время там замечено движение каких-то вытянутых металлических объектов. Что-то вроде механических червей, носящихся туда-сюда по небу. У них будто шило в одном месте. Можешь убить парочку таких червей и узнать, из-за чего им так неймётся?
	}

	StylishSetup: {
		Name: Стильный вопрос
		Description: Нет такого чувства, что это место выглядит слишком скучно? Кажется, я знаю, какой стиль бы сюда вписался — ретрофутуризм! Думаешь, я в этом деле ничего не смыслю? Как бы не так, я повидал немало интерьеров, и скажу тебе вот что: это поселение бы смотрелось сногсшибательно в стиле вейпорвейва!
	}

	ZombieOriginQuest: {
		Name: Безбожная работёнка
		Client: Отсутствует
		Description: Мне удалось найти странный свиток с бесценной информацией о том, кем на самом деле являются зомби и, возможно, даже откуда они берутся. Нужно срочно рассказать об этом гиду или дриаде. С их помощью я смогу остановить эти проклятые деяния!
		ShowGuideDialogue: Этот свиток оттуда, откуда я думаю? Очень любопытно, быть может, эта зацепка наконец позволит нам узнать, почему в последнее время на поверхности бродит так много зомби. Думаю, сперва нам нужно докопаться до правды — отправляйся в Темницу, в её архивах должны быть книги о том, кто мог устроить это восстание зомби. Это мог быть какой-нибудь безумный учёный, или кто-то вроде него...
		TalkGuide: Поговорить о загадочном свитке с гидом
		GetLureGuide: По записям в книгах трудно понять наверняка, но, судя по всему, управляет всеми ордами зомби действительно некий сошедший с ума учёный. Нам нужно придумать, как привлечь его внимание этой ночью. Может, слепим приманку из кусочков гнилой плоти? Уверен, такая штука зацепит его взгляд.
		ReturnBooks: Отнести найденные книги гиду
		ShowDryadDialogue: На этот свиток страшно даже смотреть. Он лежал в останках какого-то зомби, так ведь? Бедное, несчастное создание... Этот свиток должен привести нас к правде о том, почему нашу землю заполонили полчища зомби. На пергаменте остались следы какого-то порошка, который пахнет так же, как и зараза, что оскверняет наш мир. Нам нужно перетереть траву из того злосчастного места и сравнить полученное с этим порошком.
		TalkDryad: Или поговорить об этом свитке с дриадой
		GetLureDryad: Так и знала! Выходит, всех этих мерзких чудищ призывает какой-то злой колдун. Нам нужно придумать, как привлечь его внимание этой ночью. Попробуй изготовить приманку из того гнилостного порошка. Выжди момент и прикончи колдуна — только так мы сможем избавить эти земли от зомби!
		ReturnPowder: Отнести порошок дриаде
		KillScientist: Убить мёртвого учёного
		KillWarlock: Убить мёртвого чернокнижника
	}

	BreakingAndEntering: {
		Name: Ворваться с ноги
		Description: Мои знакомые разведчики обнаружили в одном дальнем уголке этого мира какое-то высокое здание, а на самой её вершине — связанную девушку. Надо бы вломиться туда и проведать её. Может, её спасти надо? Да и в любом случае, представь, сколько из той башни можно вынести сокровищ!
		Dialogue: "{$NPCs.Gambler.Dialogue.Bound}"
		Objective: Найти таинственную башню гоблинов и спасти пленницу.
	}

	CritterCaptureBlossmoon: {
		Name: Заповедник: цветы умиротворения
		Description: Поговаривают, что в самые спокойные из ночей наружу выползают такие зверушки, которых нигде больше на свете не увидишь. Вот войдёт луна в свою третью или седьмую фазу, подует сильный ветерок, и мы сможем наконец увидеть маленьких лунников, купающихся в ночном свете. Создания очень хрупкие, однако, так что мы должны поймать парочку для нашего заповедника.
		Thanks: Не все знают, но лунники умеют успокаивать чудовищ рядом с собой. Должно быть, этому они научились у самой луны. Если мы позаботимся о том, чтобы эти создания не вымерли, всем от этого будет только лучше. Первый шаг мы уже сделали, так держать! 
		BringBack: Отнести лунников дриаде
	}

	CritterCaptureFloater: {
		Name: Заповедник: подводные светила
		Description: Я нашла ещё один вид, что нуждается в нашей помощи. В отличие от большинства медуз, сверкающие поплавки совершенно беззащитны перед угрозой вымирания. Они пересекают океан по ночам огромными стаями, из-за чего иногда кажется, что перед тобой одна огромная медуза. Поймай поплавка и неси его мне, я позабочусь о нём и всём его виде.
		Thanks: Из-за этих чудес природы по ночам загорается огоньками всё морское дно. Было бы обидно застать их вымирание от рук морских хищников или жадных рыбаков. Они прекрасно дополнят мой сказочный заповедник. Большое тебе спасибо.
		BringBack: Отнести сверкающего поплавка дриаде
		AnglerThanks: Как же аппетитно выглядит! А главное: мне достанется вся порци- а, ты ещё здесь? Ну ладно, держи, наслаждайся, но не думай, что в следующий раз я тоже буду таким щедрым!
		ReturnAngler: Отнести сырую рыбу рыбаку
		UpsetDryad: Ах, какое наглое, избалованное дитё! Я раз за разом прощала ему ловлю редких морских созданий, но теперь моё терпение лопнуло. Поплавками нужно любоваться, а не объедаться! Пусть мечтает сколько влезет, главное, что до самих медуз он ещё не добрался. Я ценю твою преданность природе этого мира, вот, прими это как мою благодарность. Не забудь принести мне поплавка!
		Tattle: Или рассказать дриаде о планах рыбака
		HungryAngler: Её величество дриада, видите ли, знает, как правильно распорядиться очередной медузой. А мне всё равно! Как по мне, лучше всего эту медузку пустить на какой-нибудь шедевр из морепродуктов и слопать, да поскорее! Так чего же мы ждём?
		AskAngler: Или поговорить о сверкающих поплавках с рыбаком
	}

	LumothQuest: {
		Name: Заповедник: его светлейшество
		Description: У всех нас — дриад — есть клятва защищать всё живое: присматривать за братьями нашими меньшими, так сказать. В особенности это касается тех, кто сам защитить себя не может, например очаровательных люмосов, чьи лампочки освещают путь в тёмных пещерах. Принеси мне одну такую кроху, и я позабочусь о том, чтобы их вид процветал.
		Thanks: Ну ты только посмотри, какой красавец! Благодаря твоей доброте им больше не грозит никакое вымирание. Надо будет воспользоваться своей магией и создать полноценный заповедник для этого малютки и его сородичей.
		BringBack: Отнести люмоса дриаде
		MerchantDialogue: Послушай, я рад, что дриада заботится о сохранении природы, но ты только представь, сколько на этих зверушках навариться можно! Люмосы очень редкие, а я слишком хилый: вообще ни одного сам не поймаю. Что, если ты убьёшь одного люмоса и принесёшь мне его лампочку? Обещаю, получишь от меня щедрую награду!
		TalkMerchant: Или поговорить о люмосах с торговцем
		ThanksMerchant: Не переживай, от одного убитого мотылька природе ведь ничего не будет, да? Ни слова об этом дриаде, как бы то ни было. Никакие мы не чудовища, мы лишь удовлетворяем спрос на рынке ярких лампочек. Как и обещал, вот твоя награда. Приятно иметь с тобой дело! 
		BringBackMerchant: Отнести яркую лампочку торговцу
	}

	SporeSalvage: {
		Name: Заповедник: спорное спасение
		Description: Поля светящихся грибов кишмя кишат разнообразной флорой и фауной. Однажды там заметили и один разумный гриб, и он совсем не враждебен! Он только то и делает, что качается из стороны в сторону, будто пританцовывая. Мы должны позаботится о процветании его вида, хотя бы потому что этот гриб чертовски милый!
	}

	CritterCaptureSoulOrb: {
		Name: Заповедник: душа по душе
		Description: В удивительном новом месте за горизонтом, что прозвали лесом духов, проживает великое множество всяких видов животных и растений. Но одна душонка оттуда вот вот исчезнет с лица земли, если мы её не поможем. Речь про сферы духов, чьё свечение оживляет всё подземелье того места. Тебе нужно их спасти, а если получится, то и прихватить с собой один душецвет.
		Thanks: В этих сферах, похоже, запечатаны души неупокоенных существ. Быть может, все они смогут обрести покой в моём заповеднике. Сегодня мы сделали кое-что поистине важное для этих духов и всей природы. Благодарю тебя.
		BringBack: Отнести сферу духов дриаде
		ThanksSoulbloom: Эти цветы прямо таки дух захватывают, они словно из другого мира. Спасибо тебе за них. Посади их семена где-нибудь под домом — целая поляна распустится!
		BringBackSoulbloom: Отнести сферу духов и душецвет дриаде
	}

	DecrepitDepths: {
		Name: Дряхлое захоронение
		Description: Хочешь узнать, почему под землёй бродит так много скелетов? Оказывается, это всё проделки шайки некромантов, что укрывались в пещерах по всему миру и проводили свои гнусные ритуалы. Хорошо, что их уже давно нет! Но вот их склепы всё ещё остались. Сходишь туда, поизучаешь? Только в скелета не превратись!
	}

	ExplorerQuestAsteroid: {
		Name: Космические камни
		Description: Прямо над одним из океанов расположилось целое поле астероидов, и никто ещё там не был! Когда ещё такую крутотень увидишь?! Нам нужно разузнать всё про всё об этом месте. Наткнёшься на эти астероиды — оглядись вокруг, потом о находках расскажешь, хорошо? Иди давай, только на землю не свались!
		Objective: поле астероидов
	}

	ExplorerQuestAurora: {
		Name: Любование небом
		Description: Честно, это задание я даю, чтобы хоть кто-то смог насладиться красотой нашей природы. Тебе уже удавалось увидеть северное сияние? В мире столько всякой магии существует, но это явление — самое магическое, самое завораживающее, что в нём есть! Застать сияние можешь в тундре или забравшись как можно выше. Давай, иди любуйся.
		Objective: северное сияние в заснеженной тундре или на большой высоте.
	}

	ExplorerQuestBlueMoon: {
		Name: Голубая луна, голубая...
		Description: Мир всегда найдёт, чем ещё насолить нам. Все ведь мы уже знаем про жуткие кровавые луны, но в последнее время луна начала загораться и ярко-синим цветом! Звучит, конечно, романтично, но в такие ночи из под земли выползают твари ещё более ужасные, чем тебе доводилось видеть. Не подпускай их близко к поселению, хорошо?
		Objective: таинственную луну
	}

	ExplorerQuestCorrupt: {
		Name: Мерзкая пустошь
		Description: Значит, ты в этом мире ещё надолго? Нам предстоит многое исследовать, чтобы во всём здесь разобраться. Для начала нужно выяснить, насколько опасны эти искажённые разломы и обитающие там пожиратели. Если сможешь выжить в тех разломах, значит сможешь исследовать и другие опасные места, о которых писал приключенец в своём журнале.
		Objective: искажение
	}

	ExplorerQuestCrimson: {
		Name: Телесные ужасы
		Description: Значит, ты в этом мире ещё надолго? Нам предстоит многое исследовать, чтобы во всём здесь разобраться. Для начала нужно выяснить, насколько опасны эти багрянцевые поля. Боец из меня никудышный, так что тебе придётся отправиться туда в одиночку. Если сможешь выжить на тех полях, значит сможешь исследовать и другие опасные места, о которых писал приключенец в своём журнале.
		Objective: багрянец
	}

	ExplorerQuestGranite: {
		Name: Гранит науки
		Description: Видал я как-то пещеры, что целиком состояли из тёмного гранита. В них ещё бушует какая-то странная магия, из-за которой камни оживают. Пойди-ка да разведай, что там да как. Найдёшь такую пещеру — походи по ней, поизучай, потом о находках расскажешь, хорошо?
		Objective: гранитную пещеру
	}

	ExplorerQuestHive: {
		Name: Пчеловодство
		Description: В подземных джунглях доводилось бывать? Я слышал, что там повсюду огроменные ульи. Терпеть не могу пчёл... и шершней... и растений-людоедов. Так что, разведаешь для меня, где там эти ульи зарыты?
		Objective: огромный улей в джунглях
	}

	ExplorerQuestLuminous: {
		Name: Высокая, сияющая волна
		Description: Я очень люблю пляж. Наверное, сейчас тебе на ум приходят солнце и песок, и это всё я тоже очень люблю! Но больше всего я люблю ночной пляж. Если повезёт, можно увидеть, как волна выносит на берег светящиеся водоросли, из-за которых вода переливается красивыми цветами! Очень советую тебе как-нибудь прилечь у сияющего океана и расслабиться.
		Objective: сияние океана на пляже
	}

	ExplorerQuestMarble: {
		Name: Забытая цивилизация
		Description: Мне нужно, чтоб кто-нибудь залез как можно глубже в недра этой земли и составил карту пещер, сплошь покрытых мрамором. Найдёшь такую пещеру — походи по ней, поизучай, потом расскажешь, правда ли, что там остались руины какой-то древней цивилизации. Надеюсь, никого из той цивилизации не повстречаешь — говорят, кусаются.
		Objective: мраморную пещеру
	}

	ExplorerQuestMushroom: {
		Name: Синий свет в конце туннеля
		Description: Мне срочно нужно выяснить, нет ли где-нибудь рядом пещеры светящихся грибов. Видишь ли, у нас тут с торговцем спор завязался. Я ему говорю, что они существуют, не могли же мне померещиться гигантских размеров светящиеся синие грибы? Хотя, если так подумать, звучит это реально бредово, но клянусь, они существуют! Иди и докажи ему, что я был прав!
		Objective: пещеру светящихся грибов
	}

	ExplorerQuestOcean: {
		Name: На одной волне
		Description: Знаешь, зачем я постоянно отправляю тебя ловить всяких тварей? Я мечтаю увидеть каждую грёбаную рыбёху на этом свете до того, как склею ласты! И хочу, чтоб хоть кто-то был со мной на одной волне в этом деле! Погрузись как-нибудь на самое дно океана, насладись красотой и прихвати с собой что-нибудь для меня!
		Finish: Пахнет... просто ужасно! Чем вообще эти штуки так нравятся рыбкам? Можно было принести мне что-нибудь и покруче. Ну и ладно... оставь это себе. Если будешь плавать там ещё, поймай лучше мне какую-нибудь рыбу!
		Return: Отнести отложения серы рыбаку
		GetSulfur: Собрать отложения серы (5 шт.) с гидротермальных источников
		Ocean: глубины океана
	}

	FriendSafari: {
		Name: Охота за друзьями
		Description: Пару лет назад я вёл дела с одним своим другом, что любил иной раз переступить закон. Бандитом он был, понимаешь ли, причём толковым! С тех пор мы часто обменивались письмами, но сейчас он что-то перестал отвечать. В последний раз я видел его с бандой разбойников далеко отсюда. Проведаешь его?
		Dialogue: "{$NPCs.Rogue.Dialogue.Bound}"
		Objective: Найти укрытие бандитов и спасти пленника.
	}

	GranitechQuest: {
		Name: Будущее уже наступило
		Description: Я тут то и дело натыкаюсь на кое-какие запчасти... фантастические вещицы, погляди! Микросхемы в них гораздо лучше тех, что делаю я, они будто прямиком из будущего! Не терпится поковыряться в них ещё побольше. Сможешь достать мне ещё горстку таких? Этих компонентов полным-полно в кое-каких опасных устройствах, что я видела. Осторожнее с ними!
		BringBack: Отнести компоненты механику
		Thanks: Ого! Эти запчасти будто из другого мира, настолько они крутые! Говоришь, пришлось разломать пару высокоточных лазерных турелей, чтобы их достать? Мда, турели это круто, конечно, но из этих микросхем ведь можно сделать столько всего ещё более крутого! Удивительное сочетание магии и электроники, я такого никогда не видела! Люди, что изготовили такое, наверняка крайне опасны. Надо бы насобирать как можно больше компонентов, пока они не одумались!
	}

	HeartCrystalQuest: {
		Name: Дела сердечные
		Description: Если хочешь выжить в этом мире и разгадать все его тайны (разумеется, не без моей помощи), тебе нужно быть смелее — сжать сердце в кулак... а лучше десять сердец... Понимаешь, к чему я веду? Отправляйся в пещеры и найди там парочку кристаллов жизни — они придадут тебе сил. После этого ты уже сможешь взяться за более сложные задания от приключенца.
	}

	IceDeityQuest: {
		Name: Под толщей льда
		Description: Приветствую тебя! У меня для тебя довольно необычное поручение. Видишь ли, в последнее время я ощущаю какую-то странную энергию из глубин заснеженной тундры, чувствую что-то неладное. Тебе нужно будет спуститься туда и узнать, что там происходит, но сперва поспрашивай людей. Расскажешь мне, если выяснишь у них что-нибудь.
		KillWinterborn: Узнать о прошлом тундры, убивая зиморождённых
		KillCrystalDrifter: Убить скитающийся кристалл
		CuriousRelic: Какая удивительная вещица! Похоже, она откололась от какой-то большой статуи. Быть может, она была посвящена какому-то божеству, которому поклоняются зиморождённые? Или же статую возвела одна из десятков других цивилизаций, захороненных под толщами льда. Кто его знает? Но штуковина всё равно очень любопытная, хотелось бы мне однажды восстановить эту скульптуру. Сможешь найти остальные её части? Один кусочек точно можно достать из скитающихся кристаллов - странных летающих созданий, что выходят на свет во время метелей. Остальные кусочки наверняка можно выскребать из криолитовой руды и жгучего льда, осталось лишь найти их в пещерах.
		ShowRelic: Показать загадочную реликвию чародею
		GiveAllArtifacts: Отнести все артефакты чародею
		Congrats: Замечательно! Из этих артефактов будто бы складывается гигантская скульптура, изображающая какого-то воина-рыцаря или божество. Возможно какой-то древний житель тех земель лепил эту скульптуру как украшение для дома. Нам ещё столько всего предстоит узнать об их цивилизации! И хотя мы так и не узнали, отчего ледяные пещеры стали таким опасным местом, я рад, что нам удалось совершить, так сказать, небольшое археологическое открытие! Надеюсь, ты поставишь эту скульптуру куда-нибудь на видное место!
		FrozenSoulScene: Приблизившись к этому духу, вы вдруг чувствуете, как земля под вашими ногами начинает дрожать. Стены начинают обрушаться, и вскоре вы находите себя посреди бездонного ущелья. Здесь нет никого кроме вас и ледяного духа. От него начинает исходить слабое свечение, и под своими ногами вы замечаете несметные богатства, покрытые тонким слоем хрустящего инея. Дух перед вами спокойно ждёт, пока вы примете своё решение.
		FindFrozenSoul: Или найти запертую в ледяных пещерах душу
		DryadMyths: Хочешь поговорить о ледяных пещерах? Что ж, появились они задолго до моего рождения — да, не такая уж я и старая. Я слышала множество рассказов, как в этом холодном месте зарождались и вымирали целые цивилизации. Какие-то из них были мирными, а какие-то замораживали своих врагов заживо развлечения ради! Их души до сих пор заточены там во льдах. Если прислушаться, можно услышать, как они до сих пор перешёптываются.
		AskMyths: Расспросить о древних мифах дриаду
		AdventurerMyths: Про древнюю историю того места я и знать не знаю, но расскажу вот что: мои знакомые не так давно наткнулись в ледяных пещерах на новую опасность — орду зиморождённых уродцев. Во время сильных метелей они даже осмеливаются выйти на поверхность. Не знаю, чем мы успели им так насолить, но бросаются они теперь на всех без разбору, в тундре никогда так опасно ещё не было!
		AskAdventurer: Расспросить о тундре приключенца
		ReturnToDialogue: Как любопытно! Эти зацепки обязательно приведут нас к правде о тундре. Зиморождённые, говоришь? Надо бы попробовать убить парочку-другую или попытаться прислушаться к разговорам тех душ, о которых говорила дриада.
		ReturnTo: Рассказать всё чародею
	}

	IdleIdol: {
		Name: Забытый идол
		Description: Пески пустыни таят много секретов. Поговаривают даже, что неглубоко под одной из таких дюн зарыт древний зиккурат. Сможешь туда наведаться да притащить мне каких-нибудь реликвий?
		ReturnToAdventurer: Отнести находку приключенцу
		Warning: "{$SinisterSands.Description}"
		ReforgedCompatLine: Создать старый идол из красного песчаникового кирпича и гладкого янтаря, которые можно найти в Зиккурате и подземной пустыне
	}

	ItsNoSalmon: {
		Name: Это не лосось...
		Description: У меня есть для тебя, э-э-э, самое нормальное задание, да! Сходи-ка в джунгли и поймай мне рыбу-шершня. Говорят, это прямо-таки деликатес. Только будь осторожней: поймать её... будет трудно. В смысле «это точно такое же задание, какое дал бы рыбак»? Я тебе не рыбак!
		ThanksAdventurer: Благодарю! Я давно мечтал её попробовать. Даже знаю как её приготовить: я тоже своего рода шеф-повар, знаешь ли. Да что уж там, я и с тобой этой рыбой поделюсь, мне не жалко! Ещё раз спасибо.
		BringBack: Отнести рыбу-шершня приключенцу
		GiveAngler: Чего?! Кто-то ходил на рыбалку и не позвал МЕНЯ? Я оскорблён, требую пойманную рыбу-шершня в качестве компенсации морального вреда! Вот, возьми эту наживку, в следующий раз поймаешь на неё рыбу и принесёшь её мне. Приключенец и сам найдёт, что поесть. Брысь отсюда!
		BringBackAngler: Или отнести рыбу-шершня рыбаку
	}

	JellyfishHunter: {
		Name: Медузная инквизиция
		Description: Я тут кучу книг перерыл: хотел узнать, почему медузы бьются током. Как оказалось, у них всех коллективный разум, а питаются они мистической энергией. Та медуза, что мне досталась с прошлого задания, подавала своим собратьям что-то вроде сигнала о помощи. Рано или поздно ты встретишься с какой-то могущественной медузой, так что будь наготове!
		Objective: Убить Лунную медузу-волшебника
	}

	ManicMage: {
		Name: Маг-маньяк
		Description: Мои разведчики донесли мне неблагую весть: далеко отсюда живёт некий колдун и наводит страх на местных. Говорят, колдун этот — гарпия-переросток с мощным магическим посохом. Твоя задача предельно проста: принеси мне его голову! Ой... я не из этих, правда. Я имел в виду: принеси мне его шляпу!
	}

	OlympiumQuest: {
		Name: Пророчество
		Description: С каждым днём мир только увядает: я чувствую, как скверная магия становится всё сильнее и сильнее. Если мы хотим противостоять силам зла, нам понадобится кое-чья помощь. В последнее время я ощущаю могущественное присутствие своей давней знакомой в глубинах мраморных пещер. Ступай же к ней, она укажет путь к избавлению от скверны.
		Dialogue: Я ждала тебя. В своих видениях я видела, что однажды явится герой, которому нужна будет моя помощь. Готова предложить тебе могущественное оружие в обмен на скромную сумму божественных монет — олимпийских драхм. Коли пожелаешь раздобыть парочку драхм, сперва одержи победу над теми, кто получил дары от самих богов. Если будет на то твоя воля, я дам тебе благословение, с которым ты сможешь найти больше таких созданий, но знай, что это может разгневать богов.
		Objective: Найти загадочную женщину в мраморной пещере
		ReturnDialogue: Ах, герой вернулся в целости и невредимости! Чудесно. Я буду рада принять твои драхмы и наградить тебя могущественным снаряжением. И возьми ещё этот священный пергамент. Если я ещё буду тебе нужна, ты сможешь призвать меня одним росчерком пера по нему. Счастливого пути, герой.
		ReturnTo: Вернуться к оракулу
	}

	RescueQuestStylist: {
		Name: Запутанная история
		Description: Я тут слышал, как из паучьего гнезда поблизости доносились крики. Должно быть, какая-то девчуля запуталась там в паутине. Я бы и сам её спас, но... у меня дел по горло. Нет, гигантских пауков я, конечно же, не боюсь, что ты. Пойди-ка лучше ты распутай её за меня.
		Dialogue: "{$LegacyDialog.317} Кто тебя, кстати, послал меня спасать? А, подрывник? Передай ему, что с этого дня он стрижётся совершенно бесплатно!"
		Objective: Отправиться в паучье гнездо и спасти пленницу
	}

	ReturnToYourRoots: {
		Name: Возвращение к корням
		Description: Знаешь, пока я сидел в той сырой пещере терновника, я... заметил кое-что: все корни растений, кажется, вели в одно и то же место, к одной... штуке. Точно даже не знаю, что это за штука, но сам я туда больше ни ногой... Быть может, ты сходишь туда и узнаешь?
		Objective: Убить Гневоплющ
	}

	SinisterSands: {
		Name: Зловещие пески
		Description: Так и знал. Стоило мне протереть эту старую штуковину, как я разглядел в ней нечто до боли знакомое. Это же идол скарабея! Предупреждаю, не трогай его лишний раз, пока не будешь обладать достаточной силой. Несколько лет назад мы целым отрядом охотились на этого скарабея, и это почти стоило нам наших жизней. Береги себя.
		Objective: Убить Скарабеуса
	}

	SkyHigh: {
		Name: Сувенир с небес
		Description: Я тут просматривал старые карты мира и узнал вот что: где-то высоко над одним из океанов расположена целая куча парящих пагод. Однако я так и не разобрался, над правым океаном они или над левым, поэтому найти эти пагоды отправляю тебя. И принеси мне оттуда что-нибудь на память, что-нибудь красивенькое! Удачи с поисками!
	}

	SlayerQuestBriar: {
		Name: Цветочные дьяволы
		Description: Нужно наведаться в терновник и показать местным тварям кто тут главный. Убьёшь несколько гончих и стебельников — и тогда, быть может, в терновнике станет поспокойнее... Хотя кого я обманываю? Эта дыра никогда не перестанет быть адом на земле.
	}

	SlayerQuestCavern: {
		Name: Жуткие и ползучие
		Description: В пещерах под нами, кажется, прижились всякие жуткие твари. Омерзительные гады, что рыгают ядовитыми парами да плодятся без остановки. Выручай-ка, наведайся к ним. Истребишь хотя бы штук десять — в пещерах уже будет не так мерзко.
		Objective: Убить: пыхтельник, споровый пыхтельник, пещерный ползун, гигантский ракушечник, саламандра или речной рак (8 шт.)
	}

	SlayerQuestClown: {
		Name: Шутки в сторону
		Description: На прошлой неделе я, как обычно, готовилась к вечеринке, как вдруг появились эти МЕРЗКИЕ клоуны и испортили всю атмосферу. Они буквально взорвали танцпол, так что я обязана отомстить им. Найди их и прикончи. Развлекать народ здесь должна только я. 
	}

	SlayerQuestDrBones: {
		Name: Ну почему зомби...
		Description: Мой коллега — эксперт в археологии — ушёл однажды в джунгли исследовать один древний храм... и не вернулся, к сожалению. До меня дошли новости о том, что он всё ещё бродит по поверхности джунглей, но уже не как человек, а как зомби. Сделай милость, прикончи-ка его. Он уже вдоволь наисследовался.
	}

	SlayerQuestMarble: {
		Name: Древний взор
		Description: Да, после убийства того ужасного создания из одного мерзкого биома мир будто бы сам не свой. Повсюду вылазит всякая жуть. Взять те же мраморные пещеры, например: там завелось чудовище с щупальцами, глазами, здоровенными зубами, да чего у него только нет! Убей-ка его по-хорошему, ладно?
	}

	SlayerQuestNymph: {
		Name: Да она чокнутая!
		Description: Знаешь ли, после многих дней, проведённых в терновнике, мне невтерпёж было снова начать крутить романы с кем-нибудь. Позвал одну даму на свидание, принарядился. Она была той ещё милашкой. Но как только я зашёл в пещеру, в которой мы собирались встретиться, она набросилась на меня и попыталась съесть! Вот ведь чудовище грязное, прикончи её!
	}

	SlayerQuestOccultist: {
		Name: Умертвить мёртвого
		Description: Мало нам было кровавых лун — на округу теперь наводит страх и взявшийся из ниоткуда некромант! Этот урод всё призывает и призывает новых зомби, небось, скоро и наше поселение захватить сможет, если мы ничего не сделаем. Так что, если увидишь его, грохни прямо на месте, понятно?
	}

	SlayerQuestScreechOwls: {
		Name: Ночная какофония
		Description: Я очень люблю животных: собачек, кошечек, и особенно кроликов! Но есть одна животина, от которой у меня душа в пятки уходит... Да, я про сову-визгунью. Ей богу, этих существ я до жути боюсь! Каждую ночь я слышу их визг, доносящийся аж из заснеженной тундры. Из-за него я заснуть не могу! Можешь прикончить хотя бы парочку из них?
	}

	SlayerQuestUGDesert: {
		Name: Всё глубже и глубже
		Description: Спустись-ка ты поглубже! Ага, поглубже в подземную пустыню! Надоедливая шваль, что там обитает, превратила жизнь простых шахтёров в невыносимую пытку. Нужно, чтоб кто-нибудь очистил для них место от этих чудищ!
	}

	SlayerQuestValkyrie: {
		Name: Полёт валькирий
		Description: Бывало такое, что ты заберёшься высоко-высоко куда-нибудь, и тут тебя начинают закидывать своими перьями надоедливые гарпии? Оказывается, бывает и похуже: где-то летают гарпии, до зубов вооружённые и с головы до ног в доспехах! Мы прозвали таких валькириями. Уверен, ты с такой справишься и раньше времени в Вальхаллу не попадёшь!
	}

	SlayerQuestVultureMatriarch: {
		Name: Мать выводка
		Description: С тех пор, как та гигантская стена из плоти была уничтожена, мир стал гораздо более страшным местом: приходится брать себя в руки и сражаться до последнего. К нам недавно заходили путники и рассказывали, что в пустыне спал громадный стервятник. Надо бы расправиться с ним, пока он не начал наводить ужас на округу.
	}

	StrangeSeas: {
		Name: Морские сказки
		Description: Эх, легендарная жемчужина морского прибоя... Я о ней уже столько историй наслушался. Это самая редкая вещица во всём мире, но у неё будто бы есть своя воля: она словно зазывает к себе, хочет, чтобы её кто-нибудь нашёл. Чувствую, что это ловушка, есть в этом деле, так скажем, подводные камни. Тебе нужно будет отыскать эту жемчужину и разобраться во всём.
		Objective: Убить странного монстра, управляющего приливом
	}

	StylistQuestSeafoam: {
		Name: Красочная лихорадка: морская пена
		Description: О, это же ты! У меня для тебя как раз задание есть. Нет, не подстричься. Мне срочно нужен кое-какой редкий материал, пущу его на новенькую краску для волос! Убьёшь для меня одну морскую мандрагору? Мне нужен их люминесцентный мешочек. Заранее спасибо!
		ReturnTo: Отнести люминесцентный мешочек стилисту
		Dialogue: Рада, что с тобой всё хорошо! Ну что, мандрагоры реально опасные, или они просто сгущают краски? Ха, хорошую шутку придумала? Ну так вот, чернила из мешочка замечательные — сделаю из них такую краску, что волосы будут красивее морской волны. Здоровская идея? Заходи ко мне ещё, если захочешь изменить свой стиль: попробовать ту новую краску, например.
	}

	UnidentifiedFloatingObjects: {
		Name: Неопознанные летающие медузы
		Description: Уже пару лет как не пью, но порой кажется, что небо загорается сотней огней! Люди говорят, что виной тому стаи светящихся медуз. Из «доказательств» есть лишь книжка от... скажем так, ненадёжного источника, так что твоя задача — собрать достоверные данные об этих медузах! Не забудь принести мне самую вкусн-, то есть самую любопытную особь!
		Objective: странное Медузное наводнение
	}
}
