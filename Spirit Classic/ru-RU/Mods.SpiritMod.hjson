	}

	TheTide: {
		OnEnd: Прилив отступает!
		NotOcean: Прилив приступает лишь у безмятежного моря.
		AlreadyActive: Прилив уже начался!
		Wave: "Волна {0}: "
	}

	JellyDeluge.OnStart: Странные медузы летят с небес!
	LuminousOcean.OnStart: Океан озаряется свечением...
	BloodMoon.DayTime: Кровавая луна может наступить только ночью.
}

BossChecklistIntegration: {
	JellyDeluge: {
		EntryName: Медузное наводнение
		SpawnInfo: Используйте [i:SpiritMod/DistressJellyItem] ночью или дождитесь естественного начала события после победы над любым боссом. Шанс начала события снижается после победы над Лунной медузой-волшебником.
	}

	TheTide: {
		EntryName: Прилив
		SpawnInfo: Используйте [i:SpiritMod/BlackPearl] в океане.
	}

	MysticMoon: {
		EntryName: Таинственная луна
		SpawnInfo: Используйте [i:SpiritMod/BlueMoonSpawn] ночью.
	}
}

GameTips: {
	SpiritGameTip0: Лунное желе — отличная вещь, чтобы подлечиться!
	SpiritGameTip1: Оверсиер не вернётся!
	SpiritGameTip2: Где-то в подземном терновнике сидит пойманный приключенец и ждёт, когда его спасут.
	SpiritGameTip3: В таинственных святилищах можно найти много полезного... или много проблем!
	SpiritGameTip4: Алмас таит неизведанную силу. Достойны ли вы её?
	SpiritGameTip5: Одолев Звёздопанцирного странника, вы сможете добывать астралит — космический металл, из которого можно сделать мощную экипировку.
	SpiritGameTip6: Океан хранит много сюрпризов. Заглядывайте туда время от времени!
	SpiritGameTip7: Дубины — удобное оружие ближнего боя, позволяющее держать врагов на расстоянии.
	SpiritGameTip8: Под землёй можно найти склепы, полные и опасностей, и хороших наград.
	SpiritGameTip9: Выполнение заданий — отличный способ получить кучу наград! Поговорите с приключенцем, чтобы получить книгу заданий!
}

