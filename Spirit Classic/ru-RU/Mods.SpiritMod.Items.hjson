	Tooltip:
		'''
		'Let's get this party started!'
		Converts regular bullets into VIP party bullets
		'''
}

PolymorphGun: {
	DisplayName: Polymorph Gun
	Tooltip:
		'''
		Turns enemies into harmless bunnies!
		Only works on enemies below half health
		'''
}

Scattergun: {
	DisplayName: Scattergun
