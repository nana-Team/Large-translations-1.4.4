		'''
}

GravityModulator: {
	DisplayName: Gravity Modulator
	Tooltip: Reduces the player's gravity significantly
}

HellEater: {
	DisplayName: Fiery Maw
	Tooltip:
		'''
		Magic attacks may shoot out fiery spit that explode upon hitting enemies
		7% increased magic damage
		'''
}

HighGravityBoots: {
	DisplayName: High-Grav Boots
	Tooltip:
		'''
		Normalizes gravity in space
		Hold DOWN to increase gravity and vertical momentum
		'''
}

IchorPendant: {
	DisplayName: Ichor Pendant
	Tooltip:
		'''
		6% increased melee damage
		Melee hits occasionally inflict Ichor
		'''
}

IllusionistEye: {
	DisplayName: Eye of the Illusionist
	Tooltip:
		'''
		Taking fatal damage instead teleports you back home
		This effects does not work if a boss is nearby
		10 minute cooldown
		'An Illusionist without a home is simply a spectre'
		'''
}

KoiTotem: {
	DisplayName: Тотем кои
	Tooltip:
		'''
		Увеличивает навык рыбной ловли, если надет или размещён поблизости
		Тотем периодически выплёвывает использованную наживку, позволяя использовать её повторно
		'''
}

BismiteShield: {
	DisplayName: Ядовитый тарджет
	Tooltip:
		'''
		Накладывает на атакующих вас врагов дебафф «{$Buffs.FesteringWounds.DisplayName}»
		Увеличивает защиту на 2 ед. за каждого врага поблизости с этим дебаффом
		Этот эффект складывается до 5 раз
		'''
}

BloodfireShield: {
	DisplayName: Кровавый скутум
	Tooltip:
		'''
		Отключает регенерацию здоровья
		Увеличивает максимальный запас здоровья на 40 ед.
		'''
}

ClatterboneShield: {
	DisplayName: Пылкий защитник
	Tooltip:
		'''
		Увеличивает защиту на 2 ед. и снижает скорость передвижения на 3% за каждого врага поблизости
		Этот эффект складывается до 5 раз
		«Между нами есть что-то особенное»
		'''
}

ExplorerTreads: {
	DisplayName: Ботинки исследователя
	Tooltip:
		'''
		Увеличивает скорость передвижения на 5% за каждые 10% потерянного здоровья
		Даёт 50% шанс уклониться от урона ловушки
		«С такими ботинками даже исследование храмов превращаются в обычную прогулку»
		'''
}

FrigidGloves: {
	DisplayName: Леденящие перчатки
	Tooltip:
		'''
		Критические удары ближнего боя будут накладывать на врагов дебафф «{$BuffName.Frostburn}»
		Увеличивает скорость атаки на 4% за каждого врага поблизости
		Этот эффект складывается до 5 раз
		'''
}

LeatherBoots: {
