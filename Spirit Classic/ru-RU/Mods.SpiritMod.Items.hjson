	Tooltip:
		'''
		50% knockback resistance while charging a club
		Charging a club gradually increases defense
		'''
}

GoldenApple: {
	DisplayName: Golden Apple
	Tooltip: Increases defense as health decreases
}

GoldShield: {
	DisplayName: Gilded Shield
