Achievements: {
	DreadAchievement: {
		FriendlyName: Это был ужасный день
		Description: Одержать победу над Ужасом — физическим воплощением страха.
	}

	ErebusAchievement: {
		FriendlyName: A Spooky Future
		Description: Одержать победу над Эребом — кошмарным чудищем из разлома.
	}

	IceDragonAchievement: {
		FriendlyName: Холодный фронт
		Description: Одержать победу над Ледниконом — ледодышащим монстром, скрывающимся в тундре.
	}

	IgnodiumAchievement: {
		FriendlyName: Огнеопасность
		Description: Одержать победу над Игнодиумом — Стражем огня.
	}

	MindFlayerAchievement: {
		FriendlyName: Что это вообще такое???
		Description: Одержать победу над Свежателем разума.
	}

	MushroomAchievement: {
		FriendlyName: Multiversal Mycologist
		Description: Collect all of the strange fungi throughout the world and give them to the Keeper.
	}

	SquidAchievement: {
		FriendlyName: Игра в кальмара
		Description: Одержать победу над Зефирным кальмаром — яростным моллюском из открытого моря.
	}

	TrueDreadAchievement: {
		FriendlyName: Это ещё не конец, малец
		Description: Одержать победу над Абсолютным Ужасом — истинной и финальной формой этого чудовища.
	}

	UltrumAchievement: {
		FriendlyName: Ультимативная форма жизни
		Description: Одержать победу над Ультрумом — Стражем жизни.
	}

	XenanisAchievement: {
		FriendlyName: Эфемерность
		Description: Одержать победу над Ксенанисом, захватчиком из неизвестного мира.
	}

	ShadowAchievement: {
		FriendlyName: The Dark World
		Description: Triumph over the Abyssal Armageddon, when creatures from another world break through the sky to destroy.
	}

	AldinAchievement: {
		FriendlyName: ???
