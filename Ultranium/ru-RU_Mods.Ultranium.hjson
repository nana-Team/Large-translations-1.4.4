	EtherealCore: {
		DisplayName: Xenanis' Core
		Tooltip:
			'''
			Increases all damage and crit by 15% when below half health
			Press the special ability key to unleash a circle of homing ethereal bolts
			This ability has a 15 second cooldown when used
			'''
	}

	FlayerBrain: {
		DisplayName: Mind of the Mindflayer
		Tooltip:
			'''
			10% increased damage and critical strike chance chance
			You have a chance to dodge enemy attacks and gain longer invincibility when hit
			Creates an eldritch aura around the player that damages nearby enemies
			Disabling the visibility will disable the aura
			however the other bonuses will become buffed
			'''
	}

	GuardianCore: {
		DisplayName: Guardian's Insignia
		Tooltip:
			'''
			15% increased damage and 10% increased critical strike chance
			increases max life and max mana by 40
			+3 max minions
			20% reduced mana usage
			'''
	}

	IceTalon: {
		DisplayName: Ледниконий коготь
		Tooltip:
			'''
			Увеличивает пробивание брони на 5 ед.
			Выпускаемые вами снаряды с некоторым шансом будут накладывать на врагов дебафф «{$BuffName.Frostburn}»
			'''
	}

	MysticTentacle: {
		DisplayName: Щупальце зефирного кальмара
		Tooltip: Увеличивает шанс критического удара на 10%
	}

	ShadowHeart: {
		DisplayName: Heart of Erebus
		Tooltip:
			'''
			+60 max life and +30 max mana
			Grants immunity to the Eldritch Decay debuff
			Gives bonuses as your health gets lower
			At 75% health, you gain 15% increased critical strike chance
			At 50% health, you gain 15% increased damage
			At 25% health, you gain 15 defense
			These buffs will stack with each other
			'''
	}

	TrueDreadHeart: {
