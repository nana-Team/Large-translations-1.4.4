			IntestinalScarf: {
				DisplayName: Кишечный шарф
				Tooltip:
					'''
					Получение большого количества урона заставляет вас выблёвывать бафф от еды в качестве наносящего урон снаряда
					Вы можете съесть выблеванную еду, чтобы восстановить бафф
					Поедание блевоты также даёт бонус к регенерации и увеличивает характеристики
					[c/b3b2af:«Не желаете ли вы послеобеденную мятную конфету, мсье?»]
					'''
			}

			StormlionChewtoy: {
				DisplayName: Жевательная игрушка штормового льва
