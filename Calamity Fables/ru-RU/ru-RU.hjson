			InkyBluePendant: {
				DisplayName: Кулон с синими чернилами
				Tooltip:
					'''
					Призывает стража в чернильной шапочке сражаться за вас
					Нажмите ПКМ над каким-либо блоком, чтобы заставить стража пустить корни в этом месте
					Пока страж находится в этом состоянии, вокруг него образуется исцеляющая аура
					На пустившем корни страже также можно прыгать, как на батуте
					Можно призвать только одного стража в чернильной шапочке
					Занимает 2 слота миньонов
					'''
			}

			LuminousMixture: {
				DisplayName: Светящийся раствор
