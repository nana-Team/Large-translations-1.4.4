			OvergrownClaw: {
				DisplayName: Заросшая клешня
				Tooltip:
					'''
					Выпускает грибную клешню, способную хвататься за врагов
					Врагами небольшого размера можно свободно размахивать и кидаться, а также бить их об землю
					Врагам большого размера можно наносить дополнительный урон, натягивая и отрывая от них клешню
					'''
			}

			PsychedelicFogMachineItem: {
				DisplayName: Генератор психоделического тумана
				Tooltip: ""
			}

			SerratedFiberCloak: {
				DisplayName: Накидка из цепких волокон
				Tooltip:
					'''
					Заменяет ваш экипированный крюк тремя мощными мицелиевыми крюками
					Удерживайте клавишу крюка, чтобы установить на месте курсора временный мицелиевый карабин
					Если прицепиться за карабин крюком, вас с огромной скоростью запустит в соответствующем направлении
					Всего можно установить только один мицелиевый карабин за раз
					'''
			}

			SporeDye: {
				DisplayName: Споровый краситель
				Tooltip: ""
			}

			SporePod: {
				DisplayName: Споровой стручок
				Tooltip:
					'''
					Устанавливает стручок червоточины, к которому можно телепортироваться в любой момент, нажав по его иконке на карте
					Стручок завянет после первой телепортации к нему или после вашей смерти
					Перезаряжается 1 минуту 30 секунд
					'''
			}

			Sporethrower: {
				DisplayName: Споромёт
				Tooltip:
					'''
					Использует споры светящегося гриба, растущего под соплом, в качестве боеприпасов
					Если использовать оружие непрерывно в течение некоторого времени, гриб выдыхается
					Споромёт будет значительно менее эффективен, если стрелять из выдохшегося гриба
					Игнорирует 10 ед. защиты врага
					'''
			}

			SyringeGun: {
				DisplayName: Инъекционный пистолет
				Tooltip:
					'''
					Попадание всеми тремя шприцами по врагу заразит его
					Трупы заражённых взрываются и выпускают облако спор, заражающих других врагов
					На месте взрыва остаются грибы, восстанавливающие ману
					'''
			}

			TechwearSporeMask: {
				DisplayName: Респиратор от Techwear
				Tooltip:
					'''
					«Для компании производителя важнее всего было именно то, как выглядит эта маска. 
					Оно и видно — ни от каких спор эта маска не защищает»
					'''
			}

			PeculiarPot: {
				DisplayName: Странноватый горшок
				Tooltip:
					'''
					Керамический горшок, наполненный необычной жидкостью
					Позволяет вам превратиться в дёготь и спрятаться в горшочке
					Пока вы находитесь в горшочке, вы не сможете использовать какое-либо оружие, однако при этом вы будете получать на {0} ед. меньше урона
					Горшок разобьётся вдребезги, если вы получите более {1} ед. урона
					Прочность горшочка начнёт постепенно восстанавливаться, если вылезти из него и немного подождать
					'''
			}

			AmpstringBow: {
				DisplayName: Лук с электризующей тетивой
				Tooltip:
					'''
					Нажмите ПКМ, чтобы выстрелить токопроводящим жвалом
					Между жвалами автоматически образуется электрическая дуга
					Враги, попавшие под действие этой электрической дуги, будут получать больше урона от стрел
					'''
			}

			CarrionDetonatorStaff: {
				DisplayName: Посох детонации падали
				Tooltip:
					'''
					Запускает раздирающие плоть песчаные порывы, способные отрывать куски от врагов
					Оторванные куски плоти сливаются, что увеличивает их размер и силу
					Нажмите ПКМ, чтобы взорвать все существующие куски плоти
					'''
			}

			DeadStormlionLarvaCageItem: {
				DisplayName: Террариум с мёртвой личинкой штормового льва
				Tooltip: «Что-то здесь не так...»
