			SludgeSlap: {
				DisplayName: Слизешлёп
				Tooltip:
					'''
					{$CommonItemTooltip.Whips}
					Покрывает слизью поражённых врагов
					Атаки миньонов по покрытым слизью врагам призывают слизнячков
					Попадания по врагам кончиком хлыста призывают дополнительных слизнячков
					«Излюбленное оружие гелевых королей»
					'''
			}

			OpulentDartgun: {
				DisplayName: Роскошный дротиковый пистолет
				Tooltip:
					'''
					Удерживайте ПКМ, чтобы получить передозировку
					Нажмите ПКМ, чтобы выстрелить шприцем, вызывающим передозировку у поражённого врага или союзника
					Передозировка увеличивает различные характеристики, но снижает скорость передвижения, предотвращает любое лечение и наносит постепенный урон
					Попадания дротиками под действием передозировки восстанавливают здоровье и ослабляют негативные эффекты
					'''
			}

