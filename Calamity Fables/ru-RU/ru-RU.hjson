			StormlionLarvaCageItem: {
				DisplayName: Террариум с личинкой штормового льва
				Tooltip: ""
			}

			StormlionWhip: {
				DisplayName: Хлыст штормового льва
				Tooltip:
					'''
					{0} ед. урона от метки призывателя по зацепленным врагам
					{$CommonItemTooltip.Whips}
					Удерживайте ЛКМ, чтобы зацепиться за врага
					На врагах, за которых вы зацепились, будет накапливаться статичное электричество
					Атаки миньонов ускоряют накопление электричества
					Отпустите ЛКМ, чтобы вызвать взрыв статичного электричества
					'''
			}

			TornElectrosac: {
				DisplayName: Оторванная электрокиста
				Tooltip:
					'''
					На удивление прыгучий орган, который может отскакивать от поверхностей
					Пассивно накапливает заряд, который высвобождается при броске шара
					Чем больше пролетит электрокиста, тем больше урона она нанесёт
					«ГО-О-О-О-Л!!!»
					'''
			}

			BouncyDart: {
				DisplayName: Прыгучий дротик
				Tooltip: Отскакивает между врагами
			}

			BrambleStaff: {
				DisplayName: Посох колючего куста
				Tooltip:
					'''
					Призывает два перекати-поля, вращающихся вокруг вас
					Перекати-поля можно запульнуть вперёд, атаковав их хлыстом
					'''
			}

			BundleOfCaltrops: {
				DisplayName: Мешок рогулек
				Tooltip:
					'''
					Удерживайте ЛКМ, чтобы раскрутить вокруг себя мешок подобно кистеню и накопить рогульки для броска
					Отпустите ЛКМ, чтобы бросить все накопившиеся рогульки перед собой
					Чем дольше вы раскручиваете мешок вокруг себя, тем больше рогулек вы сможете бросить
					Удары самим мешком во время раскручивания позволяют накапливать рогульки значительно быстрее
					'''
			}

			CloudInAMace: {
				DisplayName: Облако в булаве
				Tooltip: Разбивается вдребезги при столкновении с блоками, выпуская мощное облако, сильно отталкивающее и врагов, и вас самих
			}

			CloudySpikeBall: {
				DisplayName: Облачный колючий шар
				Tooltip: ""
			}

			CrackshotColt: {
				DisplayName: Рикошетный кольт
				Tooltip:
					'''
					Нажмите ПКМ, чтобы подбросить монетку в воздух
					При попадании по монетке, пуля отрикошетит от других подброшенных монет и полетит в ближайшего врага
					Каждый рикошет от монет значительно увеличивает урон пули
					Подбрасывание монеты тратит одну медную монету
					'''
			}

			DesertProwlerHat: {
				DisplayName: Шляпа пустынного мародёра
				Tooltip: Увеличивает стрелковый урон на 4% и шанс не потратить боеприпасы на 20%
			}

			DesertProwlerPants: {
				DisplayName: Штаны пустынного мародёра
				Tooltip:
					'''
					Увеличивает скорость передвижения на 12%
					Даёт невосприимчивость к дебаффу «{$BuffName.WindPushed}»
					'''
			}

			DesertProwlerShirt: {
				DisplayName: Рубашка пустынного мародёра
				Tooltip: Увеличивает стрелковый урон на 4%
			}

			EyetoothRipper: {
				DisplayName: Зубоглаз-потрошитель
				Tooltip:
					'''
					Забивается мясом при ударах по врагам
					Нажмите ПКМ, чтобы выбросить забившееся мясо
					[c/A1A1A1:«Что ты вообще такое? Какой-то тип человека-циркулярной пилы?»]
					'''
			}

			FanaticalMask: {
				DisplayName: Маска фанатика
				Tooltip:
					'''
					Нанесение урона накапливает энергию внутри маски
					Выпустите эту энергию, когда маска полностью заряжена, чтобы высвободить монстра, которым вы всё это время являлись
					[c/C12E0F:«Когда надежды уже нет — моли о наступлении смерти до падения их личин»]
					'''
			}

			ObsidianThrowingDagger: {
				DisplayName: Обсидиановый метательный нож
				Tooltip: Бросает 3 переливающихся ножа за раз
			}

			PlasmaRod: {
				DisplayName: Плазменный жезл
				Tooltip:
					'''
					Мощный жезл, становящийся тем сильнее, чем больше маны у вас осталось
					При полном запасе маны (от {0} ед.) жезл выпускает огромный снаряд-молнию
					При неполном запасе маны выпускает небольшие плазменные заряды
					Плазменные заряды самонаводятся и наносят дополнительный урон по врагам, поражённым снарядом-молнией
					'''
			}

			PontiffsPiper: {
				DisplayName: Дудочник понтифика
				Tooltip:
					'''
					Призывает кальмара-дудочника на вашей голове
					Кальмар-дудочник может усиливать ваших миньонов и будет становиться сильнее по мере снижения вашего здоровья
					Увеличивает максимальное количество миньонов на 1
					[c/a97171:«...на нижней стороне тарелки есть гравировка: “Приношу свои глубочайшие извинения Джованни Баттисту Памфили”»]
					'''
			}

			SpikedBall: {
				DisplayName: Шипастый шар
				Tooltip: Удерживайте Shift, чтобы бросить шар по дуге
			}

			ToxicBlowpipe: {
				DisplayName: Ядовитая духовая трубка
				Tooltip:
					'''
					Нажмите ЛКМ, чтобы выстрелить дротиком с кислотой, снижающим защиту врагов
					Нажмите ПКМ, чтобы выстрелить дротиком с нейротоксином, крадущим здоровье врагов
					Смешивать эти вещества может быть взрывоопасно...
					'''
			}

			WoodenDart: {
				DisplayName: Деревянный дротик
				Tooltip: ""
			}

			MarniteArchitectHeadgear: {
				DisplayName: Мранитовый головной убор архитектора
				Tooltip: Увеличивает дальность размещения блоков на 5
			}

			MarniteArchitectToga: {
				DisplayName: Мранитовая тога архитектора
				Tooltip: Увеличивает скорость размещения блоков на 50%
			}

			MarniteDeconstructor: {
				DisplayName: Мранитовый расщепитель
				Tooltip:
					'''
					Его механизм генерирует лучи яркого света, способные разрушать стены с большого расстояния
					Игнорирует 10 ед. защиты врага
					'''
			}

			MarniteRepulsionShield: {
				DisplayName: Мранитовый репульсионный щит
				Tooltip:
					'''
					Враги, находящиеся за вами, поражаются иглами твёрдого света, обладающими сильным отбрасыванием
					[c/FFF191:«Скажем нет ударам в спину!»]
					'''
			}

			MarniteObliterator: {
				DisplayName: Мранитовый уничтожитель
				Tooltip:
					'''
					Использует алмазную фокусировку для проецирования длинноволнового добывающего луча света
					Игнорирует 5 ед. защиты врага
					'''
			}

			CoralCage: {
				DisplayName: Коралловая клетка
				Tooltip:
					'''
					Призывает маленькую рыбу-дракона
					«Или коралловая кораль, если угодно»
					'''
			}

			DriedFishTail: {
				DisplayName: Хвост иссохшей рыбы
				Tooltip: ""
			}

			DuatsFavor: {
				DisplayName: Снисходительность Дуата
				Tooltip:
					'''
					Добавляет переключатель слева от инвентаря
					Переключатель позволяет изменить внешний вид надгробий, выпадающих при смерти
					В переключателе также можно полностью отключить появление надгробий после смерти
					Надгробия, соответствующие биому, в котором вы умерли, не считаются за надгробия для создания минибиома кладбища
					'''
			}

			FossilizedLarynx: {
				DisplayName: Окаменелая гортань
				Tooltip:
					'''
					Изменяет ваш голос
					«Отлично подходит для подражания голосу древних высохших друзей!»
					'''
			}

			GhostlySeasaddle: {
				DisplayName: Призрачное морское седло
				Tooltip: Призывает верхового велоцикампуса
			}

			PossessedTrident: {
				DisplayName: Одержимый трезубец
				Tooltip: Призывает призрачного союзника при каждом использовании
			}

			SeaRiderGreaves: {
				DisplayName: Поножи рыбы-парусника
				Tooltip:
					'''
					Увеличивает скорость передвижения на 5%
					Позволяет плавать
					«Ботинки с перепончатыми ногами...»
					'''
			}

			SeaRiderHelmet: {
				DisplayName: Шлем рыбы-парусника
				Tooltip:
					'''
					Увеличивает шанс критического удара ближнего боя на 8%
					«Немного пыльный шлем, который обычно выдаётся стражам Морского королевства»
					'''
			}

			SeaRiderTunic: {
				DisplayName: Туника рыбы-парусника
				Tooltip:
					'''
					Увеличивает урон ближнего боя на 6%
					«Туника, украшенная гербом давно расформированного полка велоцикампусовых всадников»
					'''
			}

			WarriorsAmphora: {
				DisplayName: Амфора воина
				Tooltip:
					'''
					Позволяет телепортироваться к месту вашей смерти 
					Нажмите на метку смерти на полноэкранной карте, чтобы телепортироваться к ней, расходуя одно зелье возврата
					Время перезарядки эффекта зависит от преодолённого расстояния до места смерти
					'''
			}

			CelestialDreamcassette: {
				DisplayName: Небесная грёзокассета
				Tooltip:
					'''
					Позволяет увидеть мир в ином свете
					«Из кассеты доносятся диссонирующие переливы арф...»
					'''
			}

			CloudSpriteInABottle: {
				DisplayName: Облачный дух в банке
				Tooltip: «Внутри банки слышно его жужжание»
			}

			GoldenDreamcassette: {
				DisplayName: Золотая грёзокассета
				Tooltip:
					'''
					Позволяет увидеть мир в ином свете
					«Из кассеты доносится ангельский хор...»
					'''
			}

			OldworldDreamcassette: {
				DisplayName: Грёзокассета древнего мира
				Tooltip:
					'''
					Позволяет увидеть мир в ином свете
					«Из кассеты доносятся раскаты грома...»
					'''
			}

			HeroOfHellChestplate: {
				DisplayName: Нагрудник героя ада
				Tooltip: ""
			}

			HeroOfHellGreaves: {
				DisplayName: Поножи героя ада
				Tooltip: ""
			}

			HeroOfHellMask: {
				DisplayName: Маска героя ада
				Tooltip: «Спаси меня...»
			}

			OldHunterHat: {
				DisplayName: Шляпа старого охотника
				Tooltip:
					'''
					{$Items.DesertProwlerHat.Tooltip}
					«Одеяние охотников из далёких земель»
					'''
			}

			OldHunterPants: {
				DisplayName: Штаны старого охотника
				Tooltip:
					'''
					{$Items.DesertProwlerPants.Tooltip}
					«Одеяние охотников из далёких земель»
					'''
			}

			OldHunterShirt: {
				DisplayName: Рубашка старого охотника
				Tooltip:
					'''
					{$Items.DesertProwlerShirt.Tooltip}
					«Одеяние охотников из далёких земель»
					'''
			}

			AbandonedWulfrumHelmet: {
				DisplayName: Заржавевший вульфрумовый шлем
				Tooltip:
					'''
					Потрёпанный ржавый шлем, похожий на старые модели силовой вульфрумовой брони
					Превращает владельца в вульфрумового робота
					Может быть надет в слот головы как обычная экипировка
					[c/83B87E:«Эту хлипкую броню обычно носили мародёры и грабители.]
					[c/83B87E:Её универсальность и легкодоступность сделала вульфрум международной валютой в сделках»]
					'''
			}

			EnergyCore: {
				DisplayName: Энергетическое ядро
				Tooltip:
					'''
					Пульсирует энергией
					Можно получить только с вульфрумовых роботов, усиленных вульфрумовым узлом связи
					'''
			}

			RoverDrive: {
				DisplayName: Привод скитальца
				Tooltip:
					'''
					Активирует защитную матрицу, поглощающую суммарно до 50 ед. урона и увеличивающую защиту на 10 ед.
					Для полной зарядки матрицы после поломки потребуется 10 секунд
					Получение урона во время перезарядки начнёт её сначала
					Можно переработать в промывателе на запчасти
					'''
			}

			WulfrumAcrobaticsPack: {
				DisplayName: Вульфрумовый акробатический набор
				Tooltip:
					'''
					Превращает ваш крюк в вульфрумовый канат, на котором можно раскачиваться
					Удерживайте клавишу ВВЕРХ, чтобы медленно притягиваться к точке захвата
					Автоматически пытается зацепиться за ближайшие блоки при падении с большой высоты, если не зажата клавиша ВНИЗ
					Увеличивает скорость передвижения на {0}%
					'''
			}

			WulfrumBlunderbuss: {
				DisplayName: Вульфрумовый мушкетон
				Tooltip:
					'''
					Использует для стрельбы вульфрумовый металлолом или серебряные монеты
					Игнорирует 3 ед. защиты врага
					[c/83B87E:«Основной плюс вульфрумовых механизмов в том, что даже если они ломаются быстро, то чинятся ещё быстрее.]
					[c/83B87E:Довольно часто можно встретить робота, который превратился в боеприпасы сразу после поломки»]
					'''
			}

			WulfrumController: {
				DisplayName: Вульфрумовый контроллер
				Tooltip:
					'''
					Призывает вульфрумового дроида сражаться за вас
					Удерживание ПКМ переводит всех дронов в режим сверхзаряда
					Сверхзаряженные дроны прекращают атаку, направляя свою энергию на вас
					Эта энергия ускоряет регенерацию здоровья и увеличивает защиту
					Может исцелять других игроков, если навести курсор на них
					'''
			}

			WulfrumDiggingTurtle: {
				DisplayName: Вульфрумовая черепаха-копатель
				Tooltip:
					'''
					Бросает неустойчивую горнодобывающую машину, выкапывающую небольшой туннель
					В чрезвычайных ситуациях нажмите ПКМ, чтобы мгновенно взорвать всех копающих черепах
					'''
			}

			WulfrumDrill: {
				DisplayName: Вульфрумовый бур
				Tooltip: ""
			}

			WulfrumFusionCannon: {
				DisplayName: Прототип вульфрумового многопоточного ускорителя масс
				Tooltip:
					'''
					Стреляет быстрыми сериями снарядов средней дальности
					[c/878787:«Кому нужны хлысты, когда вы можете просто призвать самого себя?»]
					'''
			}

			WulfrumHat: {
				DisplayName: Вульфрумовая шляпа с очками
				Tooltip:
					'''
					Увеличивает дальность хлыстов на 10%
					Идёт в комплекте с париком
					'''
			}

			WulfrumJacket: {
				DisplayName: Вульфрумовая куртка
				Tooltip: Увеличивает сопротивление урону на 5%
			}

			WulfrumMetalScrap: {
				DisplayName: Вульфрумовый металлолом
				Tooltip: ""
			}

			WulfrumOveralls: {
				DisplayName: Вульфрумовый комбинезон
				Tooltip: Увеличивает скорость передвижения на 5%
			}

			WulfrumProsthesis: {
				DisplayName: Вульфрумовый протез
				Tooltip:
					'''
					Запускает вульфрумовый заряд
					Нажмите ПКМ, чтобы выкачать ману из существ перед вами
					[c/83B87E:«Технология и магия вовлечены в бесконечное противостояние, где одна копирует другую.]
					[c/83B87E:Порой они работают в тандеме, как видно на примере некоторых протезов»]
					'''
			}

			WulfrumScaffoldKit: {
				DisplayName: Вульфрумовый набор строительных лесов
				Tooltip:
					'''
					Устанавливает временные металлические леса
					Расходует один кусок вульфрумового металлолома на 40 построенных блоков
					Для установки лесов необходимо, чтобы они прилегали к цельному блоку
					[c/83B87E:«Когда в строительстве нужна скорость, а не долговечность»]
					'''
			}

			WulfrumScrewdriver: {
				DisplayName: Вульфрумовая отвёртка
				Tooltip:
					'''
					Быстро и изящно откручивает головы врагам — если те достаточно слабы
					При нанесении ударов по врагу иногда даёт вульфрумовый винт, который можно бросить, нажав ПКМ
					Если ударить отвёрткой по брошенному винту, то он полетит вперёд на большой скорости и нанесёт значительно больше урона
					[c/83B87E:«Кто делает плоскую головку отвёртки настолько большой?? Как я вообще могу этим работать?! Ей же можно глаз открутить!»]
					[c/83B87E:«...А-а»]
					'''
			}

			WulfrumTreasurePinger: {
				DisplayName: Вульфрумовый искатель сокровищ
				Tooltip:
					'''
					Находит поблизости металлы, которые, надеемся, ценнее вульфрума
					Это устройство выглядит крайне ненадёжным. [c/fc4903:Оно определённо сломается раньше, чем вы думаете]
					'''
			}

