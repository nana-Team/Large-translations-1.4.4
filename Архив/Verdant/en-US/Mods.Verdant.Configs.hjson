HeadLabel: Verdant Client Configuration
EnableSteamEffectLabel: "[i:3365] Enable Steam Effect"
EnableSteamEffectTooltip: Enables steam overlay when inside of the underground Verdant.
EnableForeOrBackgroundObjectsLabel: "[i:933] Enable Foreground/Background Objects"
EnableForeOrBackgroundObjectsTooltip: Enables decoration objects appearing in the surface background or foreground everywhere.
EnableCustomWaterfallsLabel: "[i:2169] Enable Custom Waterfalls"
EnableCustomWaterfallsTooltip: Enables waterfalls appearing from tiles, such as the Weeping Bud.
CustomDialogueSystemLabel: "[i:320] Custom Dialogue System"
CustomDialogueSystemTooltip: Allows the usage of a custom dialogue system for the Apotheosis. If turned off, will just use the chat.
FancyBookUILabel: "[i:4065] Fancy Book UI"
FancyBookUITooltip: Changes the book UI to something unique.

VerdantClientConfig: {
	DisplayName: "{$Mods.Verdant.Configs.HeadLabel}"

	EnableSteam: {
		Label: "{$Mods.Verdant.Configs.EnableSteamEffectLabel}"
		Tooltip: "{$Mods.Verdant.Configs.EnableSteamEffectTooltip}"
	}

	BackgroundObjects: {
		Label: "{$Mods.Verdant.Configs.EnableForeOrBackgroundObjectsLabel}"
		Tooltip: "{$Mods.Verdant.Configs.EnableForeOrBackgroundObjectsTooltip}"
	}

	Waterfalls: {
		Label: "{$Mods.Verdant.Configs.EnableCustomWaterfallsLabel}"
		Tooltip: "{$Mods.Verdant.Configs.EnableCustomWaterfallsTooltip}"
	}

	CustomDialogue: {
		Label: "{$Mods.Verdant.Configs.CustomDialogueSystemLabel}"
		Tooltip: "{$Mods.Verdant.Configs.CustomDialogueSystemTooltip}"
	}

	JungleSpawn: {
		Label: "[i:620] Jungle Spawn"
		Tooltip: Forces the Verdant to only spawn in the Jungle. This is less likely to overwrite most modded biomes if that is an issue. This does not work if the Center Spawn option is on.
	}

	DialogueSpeed: {
		Label: "[i:4485] Dialogue Speed"
		Tooltip: Increases or decreases the dialogue speed for all screen text.
	}

	CenterSpawn: {
		Label: "[i:9] Center Spawn"
		Tooltip: Forces the Verdant to spawn exclusively under the world's spawn. This may cause overlap with biomes like the Desert and Snow, and supercedes the Jungle Spawn config option.
	}
}
